---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ExitIntent from '../components/ExitIntent.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'MOVETOS — Kabellose Smart Infrastructure und KI-gestützte Operations Intelligence für Großveranstaltungen und kritische Infrastruktur.',
  ogImage = '/og-images/default.png'
} = Astro.props;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
  <link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}/favicon.ico`} />
  <link rel="canonical" href={`${Astro.site}${Astro.url.pathname}`} />
  <title>{title}</title>
  <style is:inline define:vars={{ base: import.meta.env.BASE_URL }}>
    @font-face { font-family: 'Outfit'; font-style: normal; font-weight: 300; font-display: swap; src: url('/movetos-co-marketing/fonts/outfit/outfit-300.ttf') format('truetype'); }
    @font-face { font-family: 'Outfit'; font-style: normal; font-weight: 400; font-display: swap; src: url('/movetos-co-marketing/fonts/outfit/outfit-400.ttf') format('truetype'); }
    @font-face { font-family: 'Outfit'; font-style: normal; font-weight: 500; font-display: swap; src: url('/movetos-co-marketing/fonts/outfit/outfit-500.ttf') format('truetype'); }
    @font-face { font-family: 'Outfit'; font-style: normal; font-weight: 600; font-display: swap; src: url('/movetos-co-marketing/fonts/outfit/outfit-600.ttf') format('truetype'); }
    @font-face { font-family: 'Outfit'; font-style: normal; font-weight: 700; font-display: swap; src: url('/movetos-co-marketing/fonts/outfit/outfit-700.ttf') format('truetype'); }
    @font-face { font-family: 'Outfit'; font-style: normal; font-weight: 800; font-display: swap; src: url('/movetos-co-marketing/fonts/outfit/outfit-800.ttf') format('truetype'); }
    @font-face { font-family: 'Outfit'; font-style: normal; font-weight: 900; font-display: swap; src: url('/movetos-co-marketing/fonts/outfit/outfit-900.ttf') format('truetype'); }
    @font-face { font-family: 'Instrument Sans'; font-style: normal; font-weight: 400; font-display: swap; src: url('/movetos-co-marketing/fonts/instrument-sans/instrument-sans-400.ttf') format('truetype'); }
    @font-face { font-family: 'Instrument Sans'; font-style: normal; font-weight: 500; font-display: swap; src: url('/movetos-co-marketing/fonts/instrument-sans/instrument-sans-500.ttf') format('truetype'); }
    @font-face { font-family: 'Instrument Sans'; font-style: normal; font-weight: 600; font-display: swap; src: url('/movetos-co-marketing/fonts/instrument-sans/instrument-sans-600.ttf') format('truetype'); }
    @font-face { font-family: 'Instrument Sans'; font-style: normal; font-weight: 700; font-display: swap; src: url('/movetos-co-marketing/fonts/instrument-sans/instrument-sans-700.ttf') format('truetype'); }
    @font-face { font-family: 'Instrument Sans'; font-style: italic; font-weight: 400; font-display: swap; src: url('/movetos-co-marketing/fonts/instrument-sans/instrument-sans-400-italic.ttf') format('truetype'); }
    @font-face { font-family: 'IBM Plex Mono'; font-style: normal; font-weight: 400; font-display: swap; src: url('/movetos-co-marketing/fonts/ibm-plex-mono/ibm-plex-mono-400.ttf') format('truetype'); }
    @font-face { font-family: 'IBM Plex Mono'; font-style: normal; font-weight: 500; font-display: swap; src: url('/movetos-co-marketing/fonts/ibm-plex-mono/ibm-plex-mono-500.ttf') format('truetype'); }
  </style>
</head>
<body>
  <Nav />
  <main>
    <slot />
  </main>
  <Footer />
  <ExitIntent />

  <script>
    // Scroll reveal
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // Nav scroll effect
    window.addEventListener('scroll', () => {
      const nav = document.querySelector('nav');
      if (nav) {
        nav.classList.toggle('scrolled', window.scrollY > 30);
      }
    });
  </script>
</body>
</html>
