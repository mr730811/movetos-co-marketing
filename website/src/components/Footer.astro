---
<footer class="border-t border-dark-border pt-12 pb-9">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="flex flex-wrap justify-between items-start gap-10">
      <div class="max-w-xs">
        <a  href={`${import.meta.env.BASE_URL}/`} class="flex items-center no-underline">
          <img src={`${import.meta.env.BASE_URL}/MOVETOS_Logo.png`} alt="MOVETOS Logo" class="h-7" />
        </a>
        <p class="text-xs text-text-muted mt-3 leading-relaxed">
          Operations Intelligence. Made in Germany.<br>
          KI-gestützte Lagebildführung und kabellose Infrastruktur.
        </p>
      </div>

      <div class="flex gap-10 flex-wrap">
        <div>
          <h5 class="font-mono text-[10px] font-medium uppercase tracking-[1.5px] text-text-muted mb-3">Lösungen</h5>
          <a  href={`${import.meta.env.BASE_URL}/senseops/`} class="block text-sm text-text-secondary hover:text-brand-orange mb-2 no-underline transition-colors">SenseOps</a>
          <a  href={`${import.meta.env.BASE_URL}/infrastruktur/`} class="block text-sm text-text-secondary hover:text-brand-orange mb-2 no-underline transition-colors">SET-System</a>
          <a  href={`${import.meta.env.BASE_URL}/infrastruktur/durchsagesysteme/`} class="block text-sm text-text-secondary hover:text-brand-orange mb-2 no-underline transition-colors">Durchsagesysteme</a>
          <a  href={`${import.meta.env.BASE_URL}/infrastruktur/leitstelle/`} class="block text-sm text-text-secondary hover:text-brand-orange mb-2 no-underline transition-colors">Mobile Leitstelle</a>
        </div>
        <div>
          <h5 class="font-mono text-[10px] font-medium uppercase tracking-[1.5px] text-text-muted mb-3">Unternehmen</h5>
          <a  href={`${import.meta.env.BASE_URL}/unternehmen/`} class="block text-sm text-text-secondary hover:text-brand-orange mb-2 no-underline transition-colors">Über uns</a>
          <a  href={`${import.meta.env.BASE_URL}/referenzen/`} class="block text-sm text-text-secondary hover:text-brand-orange mb-2 no-underline transition-colors">Referenzen</a>
          <a  href={`${import.meta.env.BASE_URL}/kontakt/`} class="block text-sm text-text-secondary hover:text-brand-orange mb-2 no-underline transition-colors">Kontakt</a>
        </div>
        <div>
          <h5 class="font-mono text-[10px] font-medium uppercase tracking-[1.5px] text-text-muted mb-3">Kontakt</h5>
          <a href="mailto:kontakt@movetos.de" class="block text-sm text-text-secondary hover:text-brand-orange mb-2 no-underline transition-colors">kontakt@movetos.de</a>
          <a href="tel:+4981572934870" class="block text-sm text-text-secondary hover:text-brand-orange mb-2 no-underline transition-colors">08157 2934870</a>
          <a  href={`${import.meta.env.BASE_URL}/senseops/demo/`} class="block text-sm text-text-secondary hover:text-brand-orange mb-2 no-underline transition-colors">Demo buchen</a>
        </div>
      </div>
    </div>

    <div class="mt-9 pt-6 border-t border-dark-border flex flex-wrap justify-between text-[11px] text-text-muted gap-4">
      <span>&copy; 2026 MOVETOS Germany GmbH · Feldafinger Str. 5, 82343 Pöcking</span>
      <span class="flex gap-3">
        <a  href={`${import.meta.env.BASE_URL}/impressum/`} class="text-text-muted hover:text-text-secondary no-underline">Impressum</a>
        <span>·</span>
        <a  href={`${import.meta.env.BASE_URL}/datenschutz/`} class="text-text-muted hover:text-text-secondary no-underline">Datenschutz</a>
        <span>·</span>
        <a  href={`${import.meta.env.BASE_URL}/agb/`} class="text-text-muted hover:text-text-secondary no-underline">AGB</a>
      </span>
    </div>
  </div>
</footer>
