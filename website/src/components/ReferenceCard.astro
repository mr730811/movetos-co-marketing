---
interface Props {
  name: string;
  category: string;
  visitors: string;
  quote?: string;
  quotePerson?: string;
  quoteRole?: string;
  highlight?: string;
  tags?: string[];
  image?: string;
}

const { name, category, visitors, quote, quotePerson, quoteRole, highlight, tags = [], image } = Astro.props;
---
<div class="reveal ref-card bg-dark-card border border-dark-border rounded-2xl overflow-hidden hover:border-brand-orange/20 hover:-translate-y-0.5 transition-all group" data-category={category}>
  {image && (
    <img src={image} alt={name} class="w-full h-36 object-cover" loading="lazy" />
  )}
  <div class="p-7">
  <div class="flex items-center gap-2 mb-4">
    <span class="font-mono text-[9px] px-2 py-0.5 bg-brand-orange-glow text-brand-orange rounded">{category}</span>
    <span class="font-mono text-[9px] text-text-muted">{visitors} Besucher</span>
  </div>

  <h3 class="font-display text-xl font-bold mb-3 group-hover:text-brand-orange transition-colors">{name}</h3>

  {highlight && (
    <div class="flex items-center gap-2 mb-4 bg-accent-green-dim rounded-lg px-3 py-2">
      <span class="text-accent-green text-sm">&#10003;</span>
      <span class="text-sm text-accent-green font-medium">{highlight}</span>
    </div>
  )}

  {quote && (
    <blockquote class="text-sm text-text-secondary leading-relaxed italic border-l-2 border-brand-orange/30 pl-4 mb-4">
      &ldquo;{quote}&rdquo;
    </blockquote>
  )}

  {quotePerson && (
    <div class="text-xs text-text-muted">
      — {quotePerson}{quoteRole && `, ${quoteRole}`}
    </div>
  )}

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-4">
      {tags.map(tag => (
        <span class="font-mono text-[9px] px-2 py-1 bg-surface border border-dark-border rounded text-text-muted">{tag}</span>
      ))}
    </div>
  )}
  </div>
</div>
