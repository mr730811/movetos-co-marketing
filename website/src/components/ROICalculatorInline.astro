---
---
<div class="roi-calc bg-white border border-dark-border rounded-2xl p-8" style="box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
  <div class="grid grid-cols-3 gap-4 mb-6">
    <div>
      <label class="block font-mono text-[10px] uppercase tracking-wider text-text-muted mb-1.5">Geländefläche (m²)</label>
      <input type="number" id="eff-area" value="50000" class="w-full px-3.5 py-2.5 rounded-lg border border-dark-border bg-white text-text-primary font-display text-base font-semibold outline-none transition-colors focus:border-brand-orange" />
    </div>
    <div>
      <label class="block font-mono text-[10px] uppercase tracking-wider text-text-muted mb-1.5">Sicherheitspersonal</label>
      <input type="number" id="eff-staff" value="40" class="w-full px-3.5 py-2.5 rounded-lg border border-dark-border bg-white text-text-primary font-display text-base font-semibold outline-none transition-colors focus:border-brand-orange" />
    </div>
    <div>
      <label class="block font-mono text-[10px] uppercase tracking-wider text-text-muted mb-1.5">Event-Dauer (Tage)</label>
      <input type="number" id="eff-days" value="3" class="w-full px-3.5 py-2.5 rounded-lg border border-dark-border bg-white text-text-primary font-display text-base font-semibold outline-none transition-colors focus:border-brand-orange" />
    </div>
  </div>

  <div class="border-t border-dark-border pt-5 mt-2">
    <p class="font-mono text-[10px] uppercase tracking-widest text-text-muted mb-4">Ihr Effizienzgewinn mit MOVETOS</p>

    <div class="flex flex-col gap-2">
      <div class="flex items-center gap-2 text-sm text-text-secondary">
        <span class="text-accent-green text-xs">&#10003;</span>
        <span><span id="eff-hours" class="font-semibold text-text-primary">60</span> Koordinationsstunden gespart</span>
      </div>
      <div class="flex items-center gap-2 text-sm text-text-secondary">
        <span class="text-accent-green text-xs">&#10003;</span>
        <span><span id="eff-saved" class="font-semibold text-text-primary">6</span> Sicherheitskräfte weniger nötig</span>
      </div>
      <div class="flex items-center gap-2 text-sm text-text-secondary">
        <span class="text-accent-green text-xs">&#10003;</span>
        <span>Ø <strong class="text-text-primary">8 Min.</strong> schnellere Reaktion durch Echtzeit-Alerts</span>
      </div>
    </div>

    <div class="mt-5 pt-4 border-t-2 border-brand-orange flex justify-between items-baseline">
      <span class="font-display text-sm font-semibold text-text-primary">Weniger Aufwand, mehr Kontrolle</span>
      <span class="font-display text-lg font-800 text-accent-green">Effizienter</span>
    </div>

    <a href={`${import.meta.env.BASE_URL}/terrops/demo/`} class="btn btn-primary w-full justify-center mt-5">
      Individuelle Berechnung anfragen &rarr;
    </a>
  </div>
</div>

<script>
  function initEfficiency() {
    const area = document.getElementById('eff-area') as HTMLInputElement;
    const staff = document.getElementById('eff-staff') as HTMLInputElement;
    const days = document.getElementById('eff-days') as HTMLInputElement;

    if (!area || !staff || !days) return;

    function calc() {
      const a = Number(area.value) || 0;
      const s = Number(staff.value) || 0;
      const d = Number(days.value) || 0;

      const hoursSaved = Math.round((a / 10000) * d * 4);
      const staffSaved = Math.round(s * 0.15);

      document.getElementById('eff-hours')!.textContent = hoursSaved.toLocaleString('de-DE');
      document.getElementById('eff-saved')!.textContent = staffSaved.toLocaleString('de-DE');
    }

    area.addEventListener('input', calc);
    staff.addEventListener('input', calc);
    days.addEventListener('input', calc);
  }

  initEfficiency();
</script>
