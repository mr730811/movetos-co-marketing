---
---
<div id="contact-form-wrapper">
  <form id="contact-form" class="bg-surface/80 backdrop-blur-xl border border-dark-border rounded-[14px] p-8">
    <div class="grid grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block font-mono text-[10px] tracking-[1px] uppercase text-text-muted mb-1.5">Name *</label>
        <input
          type="text"
          name="name"
          required
          placeholder="Max Mustermann"
          class="w-full px-4 py-3 rounded-lg border border-dark-border bg-dark text-text-primary font-body text-sm outline-none transition-colors focus:border-brand-orange"
        />
      </div>
      <div>
        <label class="block font-mono text-[10px] tracking-[1px] uppercase text-text-muted mb-1.5">Unternehmen</label>
        <input
          type="text"
          name="company"
          placeholder="Firma GmbH"
          class="w-full px-4 py-3 rounded-lg border border-dark-border bg-dark text-text-primary font-body text-sm outline-none transition-colors focus:border-brand-orange"
        />
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block font-mono text-[10px] tracking-[1px] uppercase text-text-muted mb-1.5">E-Mail *</label>
        <input
          type="email"
          name="email"
          required
          placeholder="max@firma.de"
          class="w-full px-4 py-3 rounded-lg border border-dark-border bg-dark text-text-primary font-body text-sm outline-none transition-colors focus:border-brand-orange"
        />
      </div>
      <div>
        <label class="block font-mono text-[10px] tracking-[1px] uppercase text-text-muted mb-1.5">Einsatz-Typ</label>
        <select
          name="eventType"
          class="w-full px-4 py-3 rounded-lg border border-dark-border bg-dark text-text-primary font-body text-sm outline-none transition-colors focus:border-brand-orange appearance-auto"
        >
          <option value="">Bitte wählen</option>
          <option value="festival">Festival / Konzert</option>
          <option value="stadtfest">Stadtfest / Markt</option>
          <option value="corporate">Corporate Event</option>
          <option value="kritis">KRITIS / Infrastruktur</option>
          <option value="sonstige">Sonstiges</option>
        </select>
      </div>
    </div>

    <div class="mb-4">
      <label class="block font-mono text-[10px] tracking-[1px] uppercase text-text-muted mb-1.5">Erwartete Personenzahl</label>
      <input
        type="text"
        name="visitors"
        placeholder="z.B. 20.000"
        class="w-full px-4 py-3 rounded-lg border border-dark-border bg-dark text-text-primary font-body text-sm outline-none transition-colors focus:border-brand-orange"
      />
    </div>

    <div class="mb-6">
      <label class="block font-mono text-[10px] tracking-[1px] uppercase text-text-muted mb-1.5">Nachricht (optional)</label>
      <textarea
        name="message"
        rows="3"
        placeholder="Erzählen Sie uns von Ihrem Projekt..."
        class="w-full px-4 py-3 rounded-lg border border-dark-border bg-dark text-text-primary font-body text-sm outline-none transition-colors focus:border-brand-orange resize-y"
      ></textarea>
    </div>

    <div class="mb-6">
      <label class="flex items-start gap-2.5 cursor-pointer">
        <input
          type="checkbox"
          name="privacy"
          required
          class="mt-0.5 w-4 h-4 accent-brand-orange shrink-0"
        />
        <span class="text-xs text-text-muted leading-relaxed">
          Ich stimme der Verarbeitung meiner Daten gemäß der
          <a href={`${import.meta.env.BASE_URL}/datenschutz/`} target="_blank" class="text-brand-orange hover:text-brand-orange-light underline transition-colors">Datenschutzerklärung</a>
          zu. *
        </span>
      </label>
    </div>

    <button
      type="submit"
      class="inline-flex items-center justify-center gap-1.5 w-full px-7 py-3.5 rounded-lg text-sm font-semibold bg-brand-orange text-white cursor-pointer border-none transition-all hover:brightness-110"
    >
      Demo anfragen &rarr;
    </button>

    <p class="text-[11px] text-text-muted text-center mt-3 leading-relaxed">
      Wir melden uns innerhalb von 24 Stunden. Keine Werbemails, versprochen.
    </p>
  </form>

  <div id="contact-form-success" class="hidden bg-surface/80 backdrop-blur-xl border border-dark-border rounded-[14px] py-12 px-8 text-center">
    <div class="text-5xl mb-4">&#10003;</div>
    <h3 class="font-display text-2xl font-bold mb-2 text-text-primary">Vielen Dank!</h3>
    <p class="text-[15px] text-text-secondary leading-relaxed">
      Wir melden uns innerhalb von 24 Stunden bei Ihnen.
    </p>
  </div>
</div>

<script>
  // API-Endpoint URL — anpassen wenn der Contact-API-Server deployed ist
  const CONTACT_API_URL = 'https://api.movetos.de';

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('contact-form-success') as HTMLElement;
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const data: Record<string, string> = {};
    formData.forEach((value, key) => { data[key] = value.toString(); });

    // DSGVO-konformes Consent-Logging
    data.consent_timestamp = new Date().toISOString();
    data.consent_version = '2026-03-01';
    data.consent_source = window.location.pathname;

    // Button deaktivieren während des Sendens
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Wird gesendet…';
    }

    try {
      const response = await fetch(`${CONTACT_API_URL}/api/contact`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (!response.ok) {
        const err = await response.json().catch(() => ({}));
        throw new Error(err.error || 'Serverfehler');
      }

      form.classList.add('hidden');
      success?.classList.remove('hidden');
    } catch (err) {
      // Fallback: mailto-Link öffnen bei API-Fehler
      const subject = encodeURIComponent(`Kontaktanfrage von ${data.name || 'Website'}`);
      const body = encodeURIComponent(
        `Name: ${data.name}\nUnternehmen: ${data.company || '—'}\nE-Mail: ${data.email}\nEinsatz-Typ: ${data.eventType || '—'}\nPersonenzahl: ${data.visitors || '—'}\n\nNachricht:\n${data.message || '—'}`
      );
      const fallback = confirm(
        'Die Nachricht konnte leider nicht automatisch gesendet werden.\n\nMöchten Sie die Anfrage stattdessen per E-Mail senden?'
      );
      if (fallback) {
        window.location.href = `mailto:kontakt@movetos.de?subject=${subject}&body=${body}`;
      }
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = 'Demo anfragen &rarr;';
      }
    }
  });
</script>
