---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SocialProofBar from '../../components/SocialProofBar.astro';
---
<BaseLayout
  title="MOVETOS SET — Kabellose Smart Infrastructure | MOVETOS"
  description="Kabellose, netzautarke Sicherheitsinfrastruktur für Großveranstaltungen. Kameras, Durchsagesysteme, mobile Leitstelle — aufgebaut in unter 5 Stunden."
>

<section class="pt-32 pb-20">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label mb-4">Hardware für Crowd Management</div>
    <h1 class="section-title">
      Infrastruktur, die sich dem<br>
      Event anpasst — <span class="text-brand-orange">nicht umgekehrt.</span>
    </h1>
    <p class="section-desc mt-4 max-w-2xl">
      Das Event bestimmt den Standort. Nicht die Steckdose. MOVETOS SET ist die kabellose, netzautarke Hardware-Basis für professionelles Crowd Management — aufgebaut in unter 5 Stunden, überall einsetzbar.
    </p>
  </div>
</section>

<div class="divider"></div>
<SocialProofBar compact />
<div class="divider"></div>

<!-- Key Features -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-6">
      {[
        {
          icon: '<svg class="w-7 h-7 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>',
          title: 'MOVETOS SET — Kamerasystem',
          desc: '10 kabellose Mastsysteme (5,5 m) mit HD-Kameras, LED-Beleuchtung und Lautsprechern — zusammen mit dem OCC als ein System. Plug & Play, kabellos, netzautark.',
          link: `/infrastruktur/kamerasysteme/`,
          specs: ['Full HD / 4K', 'Wetterfest IP67', 'LED-Beleuchtung', '5,5 m Masthöhe'],
        },
        {
          icon: '<svg class="w-7 h-7 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 0 1-1.44-4.282m3.102.069a18.03 18.03 0 0 1-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 0 1 8.835 2.535M10.34 6.66a23.847 23.847 0 0 0 8.835-2.535m0 0A23.74 23.74 0 0 0 18.795 3m.38 1.125a23.91 23.91 0 0 1 1.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 0 0 1.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 0 1 0 3.46"/></svg>',
          title: 'Besucher-Durchsage-System (BDS)',
          desc: 'Einzelne kabellose Durchsagesysteme mit Lautsprechern, funkangesteuert, optional mit LED-Beleuchtung und Dispatcher-Lösung für automatische Durchsagen.',
          link: `/infrastruktur/durchsagesysteme/`,
          specs: ['100V-Technik', '100 dB in 100 m', 'Sektoral steuerbar', 'Wetterfest'],
        },
        {
          icon: '<svg class="w-7 h-7 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/></svg>',
          title: 'Operation Control Centre (OCC)',
          desc: 'Ihre operative Zentrale vor Ort — Teil des MOVETOS SET Systems. Voll ausgestattet mit Bildschirmen, Netzwerk und MOVETOS Ops-Zugang. Optional mit externem Arbeitsplatz in dezentraler Leitstelle.',
          link: `/infrastruktur/leitstelle/`,
          specs: ['Schlüsselfertig', 'Multi-Monitor', 'Klimatisiert', 'Netzautark'],
        },
      ].map((item, i) => (
        <div class="reveal glass-card p-8 group hover:border-brand-orange/20 transition-all" style={`transition-delay: ${i * 0.1}s`}>
          <div class="text-3xl mb-4"><Fragment set:html={item.icon} /></div>
          <h3 class="font-display text-xl font-bold mb-3 group-hover:text-brand-orange transition-colors">{item.title}</h3>
          <p class="text-sm text-text-secondary leading-relaxed mb-5">{item.desc}</p>
          <div class="flex flex-wrap gap-1.5 mb-5">
            {item.specs.map(spec => (
              <span class="font-mono text-[9px] px-2 py-1 bg-surface border border-dark-border rounded text-text-muted">{spec}</span>
            ))}
          </div>
          <a href={item.link} class="inline-flex items-center gap-1 text-sm text-brand-orange font-medium hover:text-brand-orange-light transition-colors">
            Details &rarr;
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- Vorteile -->
<section class="py-20 md:py-28 bg-dark-card">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">Warum MOVETOS SET</div>
    <div class="section-title">Volle Flexibilität.<br>Null Kompromisse.</div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5 mt-14">
      {[
        { icon: '<svg class="w-6 h-6 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z"/></svg>', title: 'Unter 5 Stunden', desc: 'Vom Anliefern bis zum laufenden Betrieb. Plug & Play ohne Tiefbau oder Verkabelung.' },
        { icon: '<svg class="w-6 h-6 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 10.5h.375c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125H21M3.75 18h15A2.25 2.25 0 0 0 21 15.75v-6a2.25 2.25 0 0 0-2.25-2.25h-15A2.25 2.25 0 0 0 1.5 9.75v6A2.25 2.25 0 0 0 3.75 18Z"/></svg>', title: 'Netzautark', desc: 'Eigene Stromversorgung, eigenes Mesh-Netzwerk. Unabhängig von lokaler Infrastruktur.' },
        { icon: '<svg class="w-6 h-6 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418"/></svg>', title: 'Überall einsetzbar', desc: 'Wiese, Parkplatz, Innenstadt — wo auch immer Ihr Event stattfindet.' },
        { icon: '<svg class="w-6 h-6 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 0 0 2.25-2.25V6a2.25 2.25 0 0 0-2.25-2.25H6A2.25 2.25 0 0 0 3.75 6v2.25A2.25 2.25 0 0 0 6 10.5Zm0 9.75h2.25A2.25 2.25 0 0 0 10.5 18v-2.25a2.25 2.25 0 0 0-2.25-2.25H6a2.25 2.25 0 0 0-2.25 2.25V18A2.25 2.25 0 0 0 6 20.25Zm9.75-9.75H18a2.25 2.25 0 0 0 2.25-2.25V6A2.25 2.25 0 0 0 18 3.75h-2.25A2.25 2.25 0 0 0 13.5 6v2.25a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>', title: 'Modular skalierbar', desc: 'Von 5 bis 50 Maste. Das System wächst mit Ihrem Event.' },
      ].map((item, i) => (
        <div class="reveal text-center p-6" style={`transition-delay: ${i * 0.08}s`}>
          <div class="text-2xl mb-3"><Fragment set:html={item.icon} /></div>
          <h4 class="font-display text-sm font-bold mb-2">{item.title}</h4>
          <p class="text-xs text-text-muted leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- MOVETOS Ops Integration -->
<section class="py-14">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="reveal bg-gradient-to-br from-accent-blue/[0.06] to-accent-blue/[0.02] border border-accent-blue/10 rounded-2xl p-8 md:p-10 flex flex-col md:flex-row items-center justify-between gap-8">
      <div>
        <h3 class="font-display text-xl font-bold mb-2">Noch smarter mit MOVETOS Ops</h3>
        <p class="text-sm text-text-secondary max-w-lg">
          MOVETOS SET liefert die Augen und Ohren. MOVETOS Ops liefert das Gehirn. Zusammen entsteht ein geschlossener Regelkreis — vom Erkennen bis zum Steuern.
        </p>
      </div>
      <a  href={`/ops/`} class="btn btn-primary btn-sm whitespace-nowrap">MOVETOS Ops kennenlernen &rarr;</a>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- CTA -->
<section class="py-20 md:py-28 text-center">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label justify-center">Beratung</div>
    <div class="section-title mx-auto" style="max-width: 480px;">
      Welche Infrastruktur passt<br>zu <span class="text-brand-orange">Ihrem Event?</span>
    </div>
    <p class="section-desc text-center mx-auto mt-4" style="max-width: 420px;">
      Jedes Event ist anders. Wir beraten Sie individuell — von der Planung bis zur Umsetzung.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-8">
      <a  href={`/kontakt/`} class="btn btn-primary">Beratung anfragen &rarr;</a>
      <a href="tel:+4981572934870" class="btn btn-ghost">&#9742; 08157 2934870</a>
    </div>
  </div>
</section>

</BaseLayout>
