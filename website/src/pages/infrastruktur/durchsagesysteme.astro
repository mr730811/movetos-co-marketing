---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Durchsagesysteme (BDS/NDS) — Gezielte Besucherkommunikation | MOVETOS"
  description="Bereichsspezifische PA-Systeme für Großveranstaltungen. Sektoral steuerbar, wetterfest, automatisch über TerrOps ansteuerbar."
>

<section class="pt-32 pb-20">
  <div class="max-w-[1200px] mx-auto px-6">
    <nav class="flex items-center gap-2 text-xs text-text-muted mb-6">
      <a  href={`${import.meta.env.BASE_URL}/`} class="hover:text-text-secondary transition-colors">MOVETOS</a>
      <span>/</span>
      <a  href={`${import.meta.env.BASE_URL}/infrastruktur/`} class="hover:text-text-secondary transition-colors">Infrastruktur</a>
      <span>/</span>
      <span class="text-brand-orange">Durchsagesysteme</span>
    </nav>

    <div class="label mb-4">Durchsagesysteme BDS/NDS</div>
    <h1 class="section-title">
      Die richtige Information<br>am <span class="text-brand-orange">richtigen Ort.</span>
    </h1>
    <p class="section-desc mt-4 max-w-2xl">
      Bereichsspezifische Beschallungs- und Durchsagesysteme (BDS/NDS) für gezielte Besucherkommunikation. Einzeln steuerbar, automatisch über TerrOps auslösbar.
    </p>
  </div>
</section>

<div class="divider"></div>

<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-10">
      <div>
        <h2 class="font-display text-2xl font-bold mb-6">Technische Highlights</h2>
        <div class="flex flex-col gap-4">
          {[
            { label: 'Technologie', value: '100V-Liniensystem', desc: 'Professionelle ELA-Technik für beste Sprachverständlichkeit' },
            { label: 'Schallpegel', value: 'Bis 120 dB SPL', desc: 'Deutlich hörbar auch bei hohem Umgebungsgeräusch' },
            { label: 'Steuerung', value: 'Sektoral adressierbar', desc: 'Jeder Lautsprecher einzeln oder in Gruppen ansprechbar' },
            { label: 'Schutzklasse', value: 'IP65+ Wetterfest', desc: 'Zuverlässig bei jeder Witterung' },
            { label: 'Sprachsynthese', value: 'TTS-Integration', desc: 'Automatische Durchsagen in mehreren Sprachen via TerrOps' },
            { label: 'Vorlagen', value: 'Template-System', desc: 'Vordefinierte Durchsagetexte für typische Szenarien' },
          ].map((spec, i) => (
            <div class="reveal flex items-start gap-4 p-4 bg-dark-card border border-dark-border rounded-xl" style={`transition-delay: ${i * 0.06}s`}>
              <div class="flex-1">
                <div class="flex items-baseline gap-2 mb-1">
                  <span class="font-mono text-[9px] uppercase tracking-wider text-text-muted">{spec.label}</span>
                  <span class="font-display text-sm font-semibold text-text-primary">{spec.value}</span>
                </div>
                <p class="text-xs text-text-muted">{spec.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h2 class="font-display text-2xl font-bold mb-6">Intelligent mit TerrOps</h2>
        <div class="glass-card p-6 mb-6">
          <p class="text-sm text-text-secondary leading-relaxed">
            TerrOps steuert die Durchsagesysteme bereichsgenau. Bei steigender Auslastung kann automatisch eine Wegeempfehlung im betroffenen Sektor ausgelöst werden — oder der Operator bestätigt den Vorschlag per Klick.
          </p>
        </div>
        <div class="flex flex-col gap-3">
          {[
            'Automatische Durchsagen bei Kapazitätshinweisen',
            'Sektorale Ansteuerung über die Kartenansicht',
            'Mehrsprachige TTS-Sprachsynthese',
            'Vorlagen für Standardszenarien (Wegführung, Evakuierung, Notfall, Wetterwarnungen)',
            'Jingle- und Voraufnahme-Verwaltung',
            'Evakuierungsdurchsagen an betroffene Zonen — gezielt und mehrsprachig',
            'Protokollierung aller Durchsagen im Audit-Trail',
          ].map(feat => (
            <div class="flex items-center gap-2 text-sm text-text-secondary">
              <span class="text-accent-green text-xs">&#10003;</span> {feat}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<section class="py-20 text-center">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="section-title mx-auto" style="max-width: 480px;">
      Gezielte Kommunikation<br>für <span class="text-brand-orange">Ihr Event.</span>
    </div>
    <p class="section-desc text-center mx-auto mt-4">Wir planen Ihre Beschallung individuell — von einzelnen Zonen bis zur Vollabdeckung.</p>
    <div class="flex flex-wrap gap-3 justify-center mt-8">
      <a  href={`${import.meta.env.BASE_URL}/kontakt/`} class="btn btn-primary">Beratung anfragen &rarr;</a>
      <a  href={`${import.meta.env.BASE_URL}/infrastruktur/`} class="btn btn-ghost">&larr; Alle Systeme</a>
    </div>
  </div>
</section>

</BaseLayout>
