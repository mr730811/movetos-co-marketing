---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Impressum | MOVETOS Germany GmbH">

<section class="pt-32 pb-20">
  <div class="max-w-[800px] mx-auto px-6">
    <h1 class="section-title mb-8">Impressum</h1>

    <div class="prose-sm text-text-secondary leading-relaxed space-y-6">
      <div>
        <h3 class="font-display text-lg font-bold text-text-primary mb-2">Angaben gemäß § 5 TMG</h3>
        <p>
          MOVETOS Germany GmbH<br>
          Feldafinger Straße 5<br>
          82343 Pöcking<br>
          Deutschland
        </p>
      </div>

      <div>
        <h3 class="font-display text-lg font-bold text-text-primary mb-2">Geschäftsführung</h3>
        <p>Dipl.-Wirtsch.-Ing. Guntram von Nordeck</p>
      </div>

      <div>
        <h3 class="font-display text-lg font-bold text-text-primary mb-2">Kontakt</h3>
        <p>
          Telefon: +49 (0) 8157 2934870<br>
          E-Mail: kontakt@movetos.de
        </p>
      </div>

      <div>
        <h3 class="font-display text-lg font-bold text-text-primary mb-2">Handelsregister</h3>
        <p>
          Registergericht: Amtsgericht München<br>
