---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm';
---
<BaseLayout
  title="Kontakt — MOVETOS Germany GmbH"
  description="Nehmen Sie Kontakt mit MOVETOS auf. Beratung, Demo-Anfragen, Partnerschaften — wir sind für Sie da."
>

<section class="pt-32 pb-20">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <div>
        <div class="label mb-4">Kontakt</div>
        <h1 class="section-title">
          Sprechen Sie<br>
          <span class="text-brand-orange">mit uns.</span>
        </h1>
        <p class="section-desc mt-4">
          Ob Demo-Anfrage, Beratungsgespräch oder Partnerschaft — wir freuen uns auf Ihre Nachricht.
        </p>

        <div class="mt-10 flex flex-col gap-6">
          <div>
            <h4 class="font-mono text-[10px] font-medium uppercase tracking-[1.5px] text-text-muted mb-2">Telefon</h4>
            <a href="tel:+4981572934870" class="text-lg font-display font-semibold text-brand-orange hover:text-brand-orange-light transition-colors">
              +49 8157 2934870
            </a>
          </div>
          <div>
            <h4 class="font-mono text-[10px] font-medium uppercase tracking-[1.5px] text-text-muted mb-2">E-Mail</h4>
            <a href="mailto:kontakt@movetos.de" class="text-lg font-display font-semibold text-brand-orange hover:text-brand-orange-light transition-colors">
              kontakt@movetos.de
            </a>
          </div>
          <div>
            <h4 class="font-mono text-[10px] font-medium uppercase tracking-[1.5px] text-text-muted mb-2">Adresse</h4>
            <p class="text-sm text-text-secondary leading-relaxed">
              MOVETOS Germany GmbH<br>
              Feldafinger Str. 5<br>
              82343 Pöcking<br>
              Deutschland
            </p>
          </div>
        </div>
      </div>

      <div class="lg:sticky lg:top-24">
        <ContactForm client:visible />
      </div>
    </div>
  </div>
</section>

</BaseLayout>
