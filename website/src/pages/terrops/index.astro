---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SocialProofBar from '../../components/SocialProofBar.astro';
import DashboardMockup from '../../components/DashboardMockup.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import ReferenceCard from '../../components/ReferenceCard.astro';

---
<BaseLayout
  title="MOVETOS Ops — Operations Intelligence Platform | MOVETOS"
  description="MOVETOS Ops ist die KI-gestützte Operations Intelligence Plattform für Lagebildführung, Personenstromanalyse und operative Steuerung — für Events, Unternehmen und kritische Infrastruktur."
>

<!-- ===== HERO ===== -->
<section class="relative pt-32 pb-20 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-brand-orange/[0.04] via-transparent to-transparent pointer-events-none"></div>

  <div class="max-w-[1200px] mx-auto px-6 relative">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <nav class="flex items-center gap-2 text-xs text-text-muted mb-6">
          <a  href={`/`} class="hover:text-text-secondary transition-colors">MOVETOS</a>
          <span>/</span>
          <a  href={`/terrops/`} class="hover:text-text-secondary transition-colors">Lösungen</a>
          <span>/</span>
          <span class="text-brand-orange">MOVETOS Ops</span>
        </nav>

        <div class="label mb-4">
          <span class="live-dot"></span>
          Operations Intelligence Platform
        </div>

        <h1 class="font-display text-5xl md:text-6xl font-800 tracking-tight leading-[1.05]">
          MOVETOS <span class="text-brand-orange">Ops</span><br>
          <span class="text-3xl md:text-4xl font-600 text-text-secondary leading-snug block mt-2">
            Wissen, was passiert.<br>Steuern, was zählt.
          </span>
        </h1>

        <p class="text-base text-text-secondary leading-relaxed mt-6 max-w-lg">
          Die KI-Plattform für operative Lageführung. Echtzeit-Lagebild, Personenstromanalyse und gezielte Steuerung — für vorausschauende Entscheidungen statt Blindflug.
        </p>

        <div class="flex flex-wrap gap-3 mt-8">
          <a  href={`/terrops/demo/`} class="btn btn-primary">Live-Demo vereinbaren &rarr;</a>
          <a href="#how" class="btn btn-ghost">So funktioniert's</a>
        </div>
      </div>

      <div class="reveal" style="transition-delay: 0.15s">
        <DashboardMockup />
      </div>
    </div>
  </div>
</section>

<!-- Social Proof -->
<div class="divider"></div>
<SocialProofBar compact />
<div class="divider"></div>

<!-- ===== DAS PROBLEM (ohne Angst) ===== -->
<section class="relative py-20 md:py-28 overflow-hidden">
  <img src={`/images/crowd-atmosphere.jpg`} alt="" class="absolute inset-0 w-full h-full object-cover opacity-15" loading="lazy" />
  <div class="max-w-[1200px] mx-auto px-6 relative">
    <div class="max-w-2xl mx-auto text-center">
      <div class="label justify-center">Die Herausforderung</div>
      <div class="section-title mx-auto mt-4">
        Wer Verantwortung für Gelände und Menschen trägt,<br>braucht mehr als Funksprüche.
      </div>
      <p class="section-desc text-center mx-auto mt-4">
        Hunderte Entscheidungen pro Stunde — die meisten auf Basis von Bauchgefühl und fragmentierten Informationen.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-4 mt-14 max-w-3xl mx-auto">
      {[
        { q: 'Wo ist die Lage kritisch?', a: 'Funkspruch — wenn es zu spät ist' },
        { q: 'Wie viele Personen im Bereich?', a: 'Manuelle Zählung, Zeitversatz' },
        { q: 'Ist der Bereich ausgelastet?', a: 'Schätzung vom Sicherheitspersonal' },
        { q: 'Was ist vor 2 Stunden passiert?', a: 'Niemand weiß es genau' },
      ].map((item, i) => (
        <div class="reveal glass-card p-5" style={`transition-delay: ${i * 0.08}s`}>
          <div class="text-sm font-semibold text-text-primary mb-1">{item.q}</div>
          <div class="text-xs text-text-muted flex items-center gap-2">
            <span class="text-accent-red">&#10005;</span>
            {item.a}
          </div>
        </div>
      ))}
    </div>

    <div class="reveal text-center mt-10">
      <p class="text-lg font-display font-semibold text-brand-orange">
        MOVETOS Ops macht Schluss mit dem Blindflug.
      </p>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== DER CROWDOPS-LOOP ===== -->
<section class="py-20 md:py-28 bg-dark-card" id="how">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">So funktioniert's</div>
    <div class="section-title">Von der Erkennung zur Steuerung<br>— in Echtzeit.</div>
    <p class="section-desc">
      MOVETOS Ops schließt den Regelkreis zwischen Erkennen, Einordnen und gezieltem Handeln — automatisch oder vom Operator bestätigt.
    </p>

    <div class="grid md:grid-cols-3 gap-0 mt-14 relative">
      <!-- Connection line -->
      <div class="hidden md:block absolute top-[56px] left-[16.66%] right-[16.66%] h-[2px] bg-gradient-to-r from-brand-orange via-accent-blue to-accent-green opacity-30"></div>

      {[
        {
          step: '01',
          icon: '<svg class="w-7 h-7 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/></svg>',
          title: 'Erkennen',
          desc: 'MOVETOS Ops erfasst Personenzahlen, Auslastung und Bewegungsmuster über alle Kamerastandorte — kontinuierlich und in Echtzeit.',
          badge: 'bg-gradient-to-br from-brand-orange/15 to-brand-orange/5 border-brand-orange/20',
        },
        {
          step: '02',
          icon: '<svg class="w-7 h-7 text-accent-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z"/></svg>',
          title: 'Einordnen',
          desc: 'Die Plattform bewertet die Lage automatisch anhand konfigurierbarer Schwellenwerte und gibt dem Betriebsteam klare Handlungsempfehlungen.',
          badge: 'bg-gradient-to-br from-accent-blue/15 to-accent-blue/5 border-accent-blue/20',
        },
        {
          step: '03',
          icon: '<svg class="w-7 h-7 text-accent-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 0 1-1.44-4.282m3.102.069a18.03 18.03 0 0 1-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 0 1 8.835 2.535M10.34 6.66a23.847 23.847 0 0 0 8.835-2.535m0 0A23.74 23.74 0 0 0 18.795 3m.38 1.125a23.91 23.91 0 0 1 1.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 0 0 1.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 0 1 0 3.46"/></svg>',
          title: 'Steuern',
          desc: 'Bei Bedarf löst MOVETOS Ops gezielte Maßnahmen aus — von bereichsspezifischen Durchsagen bis zur Evakuierungskommunikation. Automatisch oder per Operator.',
          badge: 'bg-gradient-to-br from-accent-green/15 to-accent-green/5 border-accent-green/20',
        },
      ].map((item, i) => (
        <div class="reveal text-center px-6" style={`transition-delay: ${i * 0.12}s`}>
          <div class="font-mono text-[10px] text-text-muted tracking-wider mb-2">SCHRITT {item.step}</div>
          <div class:list={["w-14 h-14 mx-auto mb-5 rounded-2xl flex items-center justify-center text-2xl border relative z-10", item.badge]}>
            <Fragment set:html={item.icon} />
          </div>
          <h3 class="font-display text-lg font-semibold mb-2">{item.title}</h3>
          <p class="text-sm text-text-secondary leading-relaxed max-w-[280px] mx-auto">{item.desc}</p>
        </div>
      ))}
    </div>

    <div class="reveal text-center mt-12 p-5 bg-surface border border-dark-border rounded-xl max-w-2xl mx-auto">
      <p class="text-sm text-text-secondary">
        <strong class="text-brand-orange">Entscheidend:</strong> MOVETOS Ops verbindet Erkennung und Steuerung zu einem geschlossenen Regelkreis. Kein Medienbruch. Keine Verzögerung. Ihr Team behält die Kontrolle.
      </p>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== SAFETY INTELLIGENCE ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">Safety Intelligence</div>
    <div class="section-title">Sicherheit ist kein Add-on —<br><span class="text-brand-orange">sie ist eingebaut.</span></div>
    <p class="section-desc">
      MOVETOS Ops erkennt kritische Situationen, bevor sie eskalieren. MOVETOS SET ermöglicht sofortige Reaktion — gezielt, dokumentiert, nachvollziehbar.
    </p>

    <div class="grid md:grid-cols-3 gap-5 mt-14">
      <div class="reveal glass-card p-7">
        <div class="w-10 h-10 rounded-lg bg-brand-orange-glow flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
        </div>
        <h3 class="font-display text-base font-bold mb-2">Frühwarnsystem</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          Automatische Alerts bei steigender Personendichte. Konfigurierbare Schwellenwerte nach Zonen. Stufenweise Eskalation mit Handlungsempfehlungen.
        </p>
      </div>
      <div class="reveal glass-card p-7" style="transition-delay: 0.08s">
        <div class="w-10 h-10 rounded-lg bg-brand-orange-glow flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 0 1-1.44-4.282m3.102.069a18.03 18.03 0 0 1-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 0 1 8.835 2.535M10.34 6.66a23.847 23.847 0 0 0 8.835-2.535m0 0A23.74 23.74 0 0 0 18.795 3m.38 1.125a23.91 23.91 0 0 1 1.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 0 0 1.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 0 1 0 3.46"/></svg>
        </div>
        <h3 class="font-display text-base font-bold mb-2">Evakuierungsunterstützung</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          Gezielte Durchsagen an betroffene Bereiche. Zonenbasierte Kommunikation für geordnete Räumung. Lageübersicht für Einsatzleitung und BOS.
        </p>
      </div>
      <div class="reveal glass-card p-7" style="transition-delay: 0.16s">
        <div class="w-10 h-10 rounded-lg bg-brand-orange-glow flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
        </div>
        <h3 class="font-display text-base font-bold mb-2">Lückenlose Nachweispflicht</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          Jede Maßnahme wird automatisch dokumentiert. Vollständiger Audit-Trail für Behörden. Vereinfachte Genehmigungsprozesse durch belastbare Dokumentation.
        </p>
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== WAS CROWDOPS IHNEN BRINGT (Value Proposition) ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">Der Mehrwert</div>
    <div class="section-title">Was MOVETOS Ops für Ihren<br>Betrieb bedeutet.</div>
    <p class="section-desc">
      Nicht Features zählen — sondern Ergebnisse. MOVETOS Ops verändert, wie Sie Ihren operativen Betrieb führen.
    </p>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 mt-14">
      <div class="reveal glass-card p-7">
        <div class="w-10 h-10 rounded-lg bg-brand-orange-glow flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/></svg>
        </div>
        <h3 class="font-display text-base font-bold mb-2">Personal effizienter steuern</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          Sicherheitspersonal, Sanitäter und Ordnungsdienst gezielt dorthin steuern, wo sie gebraucht werden. Weniger Personalaufwand durch datenbasierte Einsatzplanung.
        </p>
      </div>
      <div class="reveal glass-card p-7" style="transition-delay: 0.08s">
        <div class="w-10 h-10 rounded-lg bg-brand-orange-glow flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75"/></svg>
        </div>
        <h3 class="font-display text-base font-bold mb-2">Abläufe optimieren</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          Engpässe vermeiden, Abläufe verbessern, Ressourcen gezielt einsetzen. Frühzeitige Entlastung kritischer Bereiche.
        </p>
      </div>
      <div class="reveal glass-card p-7" style="transition-delay: 0.16s">
        <div class="w-10 h-10 rounded-lg bg-brand-orange-glow flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z"/></svg>
        </div>
        <h3 class="font-display text-base font-bold mb-2">Schneller entscheiden</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          Echtzeit-Lagebild statt Funksprüche. Kritische Situationen erkennen und entschärfen, bevor sie eskalieren.
        </p>
      </div>
      <div class="reveal glass-card p-7" style="transition-delay: 0.24s">
        <div class="w-10 h-10 rounded-lg bg-brand-orange-glow flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>
        </div>
        <h3 class="font-display text-base font-bold mb-2">Compliance eingebaut</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          Lückenlose Dokumentation läuft automatisch mit. Sicherheitsnachweise für Genehmigungsbehörden auf Knopfdruck.
        </p>
      </div>
      <div class="reveal glass-card p-7" style="transition-delay: 0.32s">
        <div class="w-10 h-10 rounded-lg bg-brand-orange-glow flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/></svg>
        </div>
        <h3 class="font-display text-base font-bold mb-2">Team befähigen</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          MOVETOS Ops ist der Co-Pilot für Ihr Sicherheits- und Betriebsteam. Bessere Informationen für bessere Entscheidungen — der Mensch behält die Kontrolle.
        </p>
      </div>
      <div class="reveal glass-card p-7" style="transition-delay: 0.4s">
        <div class="w-10 h-10 rounded-lg bg-brand-orange-glow flex items-center justify-center mb-4">
          <svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>
        </div>
        <h3 class="font-display text-base font-bold mb-2">Datenschutz by Design</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          Keine Gesichtserkennung. Konfigurierbare Privacy-Zonen. Automatische Bildmaskierung. Datenschutz ist Architekturprinzip, kein Zusatzmodul.
        </p>
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== TERROPS FÜR IHRE BRANCHE ===== -->
<section class="py-20 md:py-28 bg-dark-card">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">MOVETOS Ops für Ihre Branche</div>
