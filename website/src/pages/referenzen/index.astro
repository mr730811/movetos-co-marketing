---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReferenceCard from '../../components/ReferenceCard.astro';
---
<BaseLayout
  title="Referenzen — Bewährt bei den Großen | MOVETOS"
  description="MOVETOS und MOVETOS Ops im Einsatz bei BMW, VW, UCI, Christkindlmarkt München und vielen mehr. Mehr als 12,7 Mio. Besucher."
>

<section class="pt-32 pb-10">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label mb-4">Crowd Management Referenzen</div>
    <h1 class="section-title">
      Bewährt bei den Großen.<br>
      Bereit für <span class="text-brand-orange">Ihr Event.</span>
    </h1>
    <p class="section-desc mt-4 max-w-2xl">
      Mehr als 12,7 Millionen Besucher. Von Volksfesten über Stadtfeste, Sportevents und Konzerte bis hin zu Corporate Events und KRITIS — unser System ist dort im Einsatz, wo es zählt.
    </p>
  </div>
</section>

<div class="divider"></div>

<!-- Referenz Grid -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <!-- Filter -->
    <div id="ref-filters" class="flex flex-wrap gap-2 mb-10">
      {['Alle', 'Corporate', 'Volksfest', 'Stadtfest', 'Sportevent', 'Konzert', 'KRITIS'].map((cat, i) => (
        <button
          data-filter={cat}
          class:list={[
            "ref-filter font-mono text-[11px] px-4 py-2 rounded-md border transition-all cursor-pointer",
            i === 0 ? 'bg-brand-orange text-white border-brand-orange' : 'bg-transparent text-text-muted border-dark-border hover:border-dark-border-hover hover:text-text-secondary'
          ]}
        >
          {cat}
        </button>
      ))}
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      <!-- Corporate -->
      <ReferenceCard
        name="BMW Motorrad Days"
        category="Corporate"
        visitors="135.000"
        highlight="Veranstaltung trotz 15% Personalausfall am Eventtag"
        quote="Sicherheit auf dem technischen Niveau ist überzeugend."
        quotePerson="H. Schmitt"
        quoteRole="Veranstalter"
        tags={['SET', 'BDS', 'MOVETOS Ops', '3x']}
        image={`/images/ref-bmw.jpg`}
      />
      <ReferenceCard
        name="VW Familie Days Wolfsburg"
        category="Corporate"
        visitors="60.000"
        highlight="Großes Firmenareal ohne einen Meter Kabel voll im Blick"
        quote="Eine solche Fläche, in Echtzeit im Blick zu haben, ist was völlig neues für die Sicherheitsplanung."
        quotePerson="H. Holzemer"
        quoteRole="Fachplaner"
        tags={['MOVETOS SET', 'MOVETOS Ops', '60 Kameras']}
        image={`/images/ref-vw.jpg`}
      />
      <ReferenceCard
        name="Tag der Bundeswehr"
        category="Corporate"
        visitors="500.000"
        highlight="15 Standorte, bis zu 45 ha Kasernenfläche ohne Kabel"
        quote="Noch nie hatten wir die kritische Liegenschaft so gut im Blick, wie jetzt."
        quotePerson="Projektleitung Bückeburg"
        quoteRole="Sicherheitsmanagement"
        tags={['SET', 'BDS', 'MOVETOS Ops', '15 Standorte']}
        image={`/images/ref-bundeswehr.jpg`}
      />
      <ReferenceCard
        name="Pioniers Day Eurocopter / Airbus"
        category="Corporate"
        visitors="35.000"
        highlight="Gesamtes Firmengelände, 0 Meter Kabel"
        quote="Einfacher kann man Sicherheit kaum planen und umsetzen."
        quotePerson="M. Weiskopf"
        quoteRole="Fachplaner"
        tags={['BDS', '10x2 Lautsprecher']}
      />
      <ReferenceCard
        name="BMW Jubiläumstage"
        category="Corporate"
        visitors="45.000"
        highlight="Aufrüstung eines Werksgeländes"
        quote="Ein Werksgelände als Eventfläche ist eine Herausforderung und eine Besucherinformations-/Notfallbeschallung ist das Basic. Wichtig ist, dass dieses Basic verlässlich und einfach funktioniert und das kann MOVETOS gut."
        quotePerson="H. Schmitt"
        quoteRole="Veranstalter"
        tags={['BDS', '12x2 Lautsprecher + Licht']}
      />
      <ReferenceCard
        name="Wiener Linien"
        category="Corporate"
        visitors="35.000"
        highlight="Innenstadt Wien, ohne Kabel, Traversen, Überfahrschutz"
        quote="Das live Lagebild macht die Veranstaltungsleitung deutlich sicherer und einfacher, für alle Beteiligten."
        quotePerson="G. Geczek"
        quoteRole="RK Wien"
        tags={['MOVETOS SET', 'MOVETOS Ops', '12 Kameras']}
      />
      <!-- Volksfest -->
      <ReferenceCard
        name="Plärrer Augsburg"
        category="Volksfest"
        visitors="1,2 Mio."
        highlight="Einbindung aller Fahrgeschäfte, 0 m Kabel verlegt"
        quote="An einem Tag alles auf und abgebaut, so einfach hatte ich es mir nicht vorgestellt."
        quotePerson="F. Wüst"
        quoteRole="Marktleiter"
        tags={['MOVETOS Ops', 'BDS', '14x2 Lautsprecher', '4x']}
      />
      <ReferenceCard
        name="Stoppelmarkt Vechta"
        category="Volksfest"
        visitors="600.000"
        highlight="Ohne Kabel und Traversen, mit Einbindung der Polizei"
        quote="Mit der Technik können wir beim nächsten Mal deutlich besser unser Personal planen."
        quotePerson="C. Thöle"
        quoteRole="Marktleiter"
        tags={['MOVETOS SET', 'MOVETOS Ops', '20 Kameras', '7 Tage']}
      />
      <ReferenceCard
        name="Japan Tag Düsseldorf"
        category="Volksfest"
        visitors="800.000"
        highlight="Entlang der Rhein Promenade"
        quote="Ein live Bild, in Farbe, von allen Standorten und das bei der Besuchermenge, hatte ich nicht geglaubt."
        quotePerson=""
        quoteRole="Veranstalter"
        tags={['MOVETOS SET', 'MOVETOS Ops', '20 Kameras']}
      />
      <!-- Stadtfest -->
      <ReferenceCard
        name="Christkindelmarkt München"
        category="Stadtfest"
        visitors="7,5 Mio."
        highlight="Im gesamten Stadtbereich keine Kabel, Traversen, Überfahrschutz"
        quote="Es war sehr einfach und ohne großen Aufwand im Aufbau und in der Bedienung. So ist Eventsicherheit einfach und sinnvoll."
        quotePerson="J. Wagle"
        quoteRole="Veranstalter"
        tags={['BDS', '16x2 Lautsprecher', '3x 30 Tage']}
      />
      <ReferenceCard
        name="Tag der Deutschen Einheit Erfurt"
        category="Stadtfest"
        visitors="300.000"
        highlight="Gesamter Innenstadtbereich ohne Kabel"
        quote="Die zentrale Veranstaltungsleitung hatte jederzeit die Lage im Blick."
        quotePerson="J. Wagner"
        quoteRole="Veranstalter"
        tags={['MOVETOS SET', 'MOVETOS Ops', '40 Kameras', '4 Tage']}
        image={`/images/ref-einheit.jpg`}
      />
      <ReferenceCard
        name="Tanz der Marktweiber"
        category="Stadtfest"
        visitors="45.000"
        highlight="Viktualien Markt München, alles ohne Kabel"
        quote="Die technischen Lösungen waren überzeugend und haben genau das gemacht, was wir erwartet haben."
        quotePerson="M. Kerscher"
        quoteRole="Marktmeister"
        tags={['SET', 'BDS', 'MOVETOS Ops', '3x']}
        image={`/images/ref-marktweiber.jpg`}
      />
      <ReferenceCard
        name="Weihnachtsmarkt Mühlheim"
        category="Stadtfest"
        visitors="15.000"
        highlight="Auf einer Ruhrinsel, alles ohne Kabel"
        quote="Mit der Lösung ist Sicherheit weder teuer noch problematisch. Das hat uns allen geholfen."
        quotePerson="T. Weber"
        quoteRole="Veranstalter"
        tags={['BDS', '4x2 Lautsprecher + Licht']}
      />
      <!-- Sportevent -->
      <ReferenceCard
        name="UCI Rad WM"
        category="Sportevent"
        visitors="1,15 Mio."
        highlight="Gesamte Innstadt ohne Kabel, Einbindung Leitstelle Tirol"
        quote="Nie war Sicherheit so einfach und zuverlässig."
        quotePerson="Mag. Noggler"
        quoteRole="Leitstelle Tirol"
        tags={['MOVETOS SET', 'MOVETOS Ops', '20 Kameras', '7 Tage']}
        image={`/images/ref-uci.jpg`}
      />
      <ReferenceCard
        name="Allianz Arena Last Mile"
        category="Sportevent"
        visitors="60.000"
        highlight="Last Mile Lösung, keine Stolperfallen vor dem Stadion"
        quote="Die Technik ist überzeugend und kann bei an jedem Stadion eingebunden werden."
        quotePerson="B. Nass"
        quoteRole="DFL"
        tags={['MOVETOS SET', 'MOVETOS Ops', '10 Kameras']}
      />
      <ReferenceCard
        name="Hockey Cup Grünwald"
        category="Sportevent"
        visitors="2.500"
        highlight="Sicherheitsrelevante Aufrüstung einer Sportanlage"
        quote="Einfach, zuverlässig und mit wenig Aufwand. Eventsicherheit wird dadurch einfacher."
        quotePerson="J. Verleger"
        quoteRole="Locationmanager"
        tags={['MOVETOS SET', 'MOVETOS Ops', '10 Kameras', '2 Tage']}
      />
      <ReferenceCard
        name="Tabaluga Golf Charity"
        category="Sportevent"
        visitors="250"
        highlight="50 ha Golfplatz, alles ohne 1 m Kabel"
        quote="Auf einem Golfplatz ist es wichtig, dass alles ohne Kabel ist, funktioniert und die Besucher sicher sind."
        quotePerson="M. Tepel"
        quoteRole="Sponsor"
        tags={['BDS', '4x2 Lautsprecher']}
        image={`/images/ref-golf.jpg`}
      />
      <ReferenceCard
        name="Après Ski Mosshütte Seefeld"
        category="Sportevent"
        visitors="8.000"
        highlight="Party-Event oben auf der Piste"
        quote="Einfacher geht Sicherheit wirklich nicht."
        quotePerson="R. Schneider"
        quoteRole="Veranstalter"
        tags={['BDS', '2x2 Lautsprecher + Licht']}
      />
      <ReferenceCard
        name="TdoT Segelsportzentrum Königsdorf"
        category="Sportevent"
        visitors="12.000"
        highlight="Auf einer grünen Wiese, alles kabellos"
        quote="Schnell auf- und abgebaut und alles da, was die Behörde wollte."
        quotePerson="A. Sternbeck"
        quoteRole="Veranstalter"
        tags={['BDS', '4x2 Lautsprecher + Licht']}
      />
      <!-- Konzert -->
      <ReferenceCard
        name="Wiener Philharmoniker Schönbrunn"
        category="Konzert"
        visitors="20.000"
        highlight="Denkmalgeschützter Schlosspark, keine Kabel erlaubt"
        quote="Echtzeitlagebild an allen Eingängen, ohne Kabel und Traversen. Das war was völlig neues."
        quotePerson="G. Geczek"
        quoteRole="RK Wien"
        tags={['MOVETOS SET', 'MOVETOS Ops', '20 Kameras']}
        image={`/images/ref-schoenbrunn.jpg`}
      />
      <ReferenceCard
        name="Ärzte Konzert Tempelhof"
        category="Konzert"
        visitors="120.000"
        highlight="4 Eingänge, 1.000 m Laufwege, 0 Meter Kabel"
        quote="Einfach in der Bedienung, und wirklich flexibel im Aufbau. Wir mussten an keine Kabel, Traversen oder Strom denken."
        quotePerson="S. Mohnen"
        quoteRole="Veranstalter"
        tags={['BDS', '6x2 Lautsprecher + Licht']}
      />
      <ReferenceCard
        name="Braas Wiesn"
        category="Konzert"
        visitors="30.000"
        highlight="Veranstaltung auf freier Wiese"
        quote="Hier muss es schnell und unkompliziert gehen und das kann das System."
        quotePerson=""
        quoteRole="Veranstalter"
        tags={['BDS', '4x2 Lautsprecher', '2x']}
      />
      <!-- Weitere -->
      <ReferenceCard
        name="Flohmarkt Münchner Wiesn"
        category="Stadtfest"
        visitors="100.000"
        highlight="Freie Fläche auf der Theresien Wiese München"
        quote="Eine freie Fläche und bei schönem Wetter viele Familien, da muss Sicherheit einfach funktionieren."
        quotePerson=""
        quoteRole="BRK, Veranstalter"
        tags={['BDS', '5x2 Lautsprecher + Licht', '3x']}
      />
      <!-- KRITIS -->
      <ReferenceCard
        name="Flughafen München"
        category="KRITIS"
        visitors="Fortlaufend"
        highlight="Einbindung in die Leitstelle Sicherheit, gesamtes Flugfeld"
        quote="In zwei Tagen einsatzbereit, das hätten wir nie gedacht, mit Datenübertragung über das gesamte Flugfeld."
        quotePerson="R. Götze"
        quoteRole="Airport"
        tags={['MOVETOS SET', 'MOVETOS Ops', '40 Kameras', '24/7']}
        image={`/images/ref-muc.jpg`}
      />
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- CTA -->
<section class="py-20 md:py-28 text-center">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="section-title mx-auto" style="max-width: 480px;">
      Ihr Event könnte<br>
      <span class="text-brand-orange">hier stehen.</span>
    </div>
    <p class="section-desc text-center mx-auto mt-4" style="max-width: 420px;">
      Erzählen Sie uns von Ihrem Projekt. Wir zeigen Ihnen, was MOVETOS und MOVETOS Ops für Sie leisten können.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-8">
      <a  href={`/ops/demo/`} class="btn btn-primary">Demo vereinbaren &rarr;</a>
      <a  href={`/kontakt/`} class="btn btn-ghost">Kontakt aufnehmen</a>
    </div>
  </div>
</section>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.ref-filter');
  const cards = document.querySelectorAll<HTMLElement>('.ref-card');

  const activeClasses = ['bg-brand-orange', 'text-white', 'border-brand-orange'];
  const inactiveClasses = ['bg-transparent', 'text-text-muted', 'border-dark-border', 'hover:border-dark-border-hover', 'hover:text-text-secondary'];

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter') || 'Alle';

      // Update button styles
      buttons.forEach(b => {
        b.classList.remove(...activeClasses);
        b.classList.add(...inactiveClasses);
      });
      btn.classList.remove(...inactiveClasses);
      btn.classList.add(...activeClasses);

      // Filter cards
      cards.forEach(card => {
        const category = card.getAttribute('data-category') || '';
        if (filter === 'Alle' || category === filter) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>

</BaseLayout>
