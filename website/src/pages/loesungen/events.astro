---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SocialProofBar from '../../components/SocialProofBar.astro';
import ROICalculator from '../../components/ROICalculatorInline.astro';
import ReferenceCard from '../../components/ReferenceCard.astro';
---
<BaseLayout
  title="Crowd Management für Großveranstaltungen | MOVETOS"
  description="KI-gestütztes Crowd Management für Festivals, Stadtfeste und Sportevents. Besucherströme in Echtzeit steuern, Kapazitäten optimieren, Sicherheit gewährleisten. Bewährt seit 2017."
>

<!-- ===== HERO ===== -->
<section class="relative pt-28 pb-16 md:pt-32 md:pb-20 overflow-hidden">
  <img src={`/images/tile-events.jpg`} alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
  <div class="absolute inset-0 bg-black/25 pointer-events-none"></div>
  <div class="max-w-[1200px] mx-auto px-6 relative">
    <div class="max-w-2xl bg-white/90 backdrop-blur-xl rounded-2xl p-8 md:p-12 shadow-lg border border-white/60">
      <div class="label mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-accent-green"></span>
        Crowd Management
      </div>
      <h1 class="font-display text-4xl md:text-5xl font-800 tracking-tight leading-[1.08]">
        Crowd Management für<br>
        <span class="text-accent-green">Großveranstaltungen.</span>
      </h1>
      <p class="text-base md:text-lg text-text-secondary leading-relaxed mt-5 max-w-xl">
        Besucherströme in Echtzeit erkennen, bewerten und steuern — mit KI-gestützter Analyse und kabelloser Infrastruktur. Aufgebaut in unter 5 Stunden. Bewährt bei Festivals, Stadtfesten und internationalen Sportevents.
      </p>
      <div class="flex flex-wrap items-center gap-3 mt-8">
        <a href={`/ops/demo/`} class="btn btn-primary">Demo vereinbaren &rarr;</a>
        <a href={`/referenzen/`} class="btn btn-ghost bg-white/50">Referenzen ansehen</a>
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== HERAUSFORDERUNGEN ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">Die Herausforderung</div>
    <div class="section-title">Tausende Besucher. Hunderte Entscheidungen.<br><span class="text-brand-orange">Ein Bauchgefühl?</span></div>
    <p class="section-desc">
      Veranstaltungsleiter stehen vor einer unmöglichen Aufgabe: Ein dynamisches Gelände mit zehntausenden Menschen überwachen — oft mit Funksprüchen, Erfahrung und Hoffnung. MOVETOS macht Schluss mit dem Blindflug.
    </p>

    <div class="grid md:grid-cols-3 gap-6 mt-14">
      {[
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/></svg>', title: 'Unübersichtliche Besucherströme', desc: 'Wo sind Engpässe? Wo ist Platz? Ohne Echtzeitdaten bleiben diese Fragen unbeantwortet — bis es zu spät ist.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>', title: 'Sicherheitsrisiken erkennen', desc: 'Kritische Personendichten entstehen in Minuten. Wer sie zu spät erkennt, kann nicht mehr steuern.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>', title: 'Compliance & Dokumentation', desc: 'MVStättVO, Genehmigungsauflagen, Behörden-Nachweise — alles muss dokumentiert werden. Manuell ist das kaum möglich.' },
      ].map(item => (
        <div class="reveal glass-card p-7">
          <div class="w-10 h-10 rounded-lg bg-brand-orange-glow flex items-center justify-center mb-3" set:html={item.icon}></div>
          <h3 class="font-display text-base font-bold mb-2">{item.title}</h3>
          <p class="text-sm text-text-secondary leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== LÖSUNG ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">Die Lösung</div>
    <div class="section-title">Ein System für den gesamten<br><span class="text-accent-green">Crowd-Management-Regelkreis.</span></div>
    <p class="section-desc">
      MOVETOS verbindet KI-Software (MOVETOS Ops) mit kabelloser Hardware (MOVETOS SET) zu einem geschlossenen Regelkreis: Erkennen → Bewerten → Steuern.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mt-14">
      {[
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>', title: 'Echtzeit-Besucheranalyse', desc: 'KI-gestützte Auswertung aller Kamerastandorte. Besucherströme, Personendichten und Bewegungsmuster — live auf dem Dashboard. Schnittstellen für Detektions-Gates, Personenklicker und Ticketsysteme.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0"/></svg>', title: 'Automatische Sicherheits-Alerts', desc: 'Schwellenwerte definieren, automatische Frühwarnung bei kritischer Auslastung. Handlungsempfehlungen direkt im System.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 0 1-1.44-4.282m3.102.069a18.03 18.03 0 0 1-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 0 1 8.835 2.535M10.34 6.66a23.847 23.847 0 0 0 8.835-2.535m0 0A23.74 23.74 0 0 0 18.795 3m.38 1.125a23.91 23.91 0 0 1 1.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 0 0 1.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 0 1 0 3.46"/></svg>', title: 'Gezielte Besucherlenkung', desc: 'Vom Kamerabild zur gezielten Durchsage — per Bereichsdurchsage (BDS) oder Notdurchsage (NDS). Ohne Medienbruch.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>', title: 'Compliance-Dokumentation', desc: 'Lückenlose Protokollierung aller Maßnahmen, Schwellenwerte und Alerts. Export-fertig für Behörden und Genehmigungsverfahren.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z"/></svg>', title: 'Interaktives Lagebild', desc: 'Kartenbasierte Echtzeitansicht des gesamten Geländes. Kameras, Zonen, Auslastung und Alerts auf einen Blick.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z"/></svg>', title: 'Aufbau in unter 5 Stunden', desc: 'Kabellose Mastsysteme, netzautarke Stromversorgung, Plug & Play. Das gesamte System steht, bevor der erste Besucher kommt.' },
      ].map(item => (
        <div class="reveal flex items-start gap-4 p-5 bg-surface border border-dark-border rounded-xl">
          <div class="shrink-0 mt-0.5" set:html={item.icon}></div>
          <div>
            <h3 class="font-display text-sm font-bold mb-1">{item.title}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== ROI CALCULATOR ===== -->
<section class="py-20 md:py-28 bg-dark-card">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-10 items-center">
      <div>
        <div class="label">Ihr Mehrwert in Zahlen</div>
        <div class="section-title">Wie viel effizienter wird<br><span class="text-brand-orange">Ihr Event?</span></div>
        <p class="section-desc">
          Echtzeit-Lagebild statt Funksprüche: weniger Koordinationsaufwand, gezielterer Personaleinsatz. Rechnen Sie mit Ihren Zahlen.
        </p>
      </div>
      <div>
        <ROICalculator />
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== REFERENZEN ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">Bewährt in der Praxis</div>
    <div class="section-title">Events, die auf<br><span class="text-accent-green">MOVETOS vertrauen.</span></div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 mt-14">
      <ReferenceCard
        name="UCI Rad WM"
        category="Sportevent"
        visitors="1,15 Mio."
        highlight="Gesamte Innstadt ohne Kabel, Einbindung Leitstelle Tirol"
        quote="Nie war Sicherheit so einfach und zuverlässig."
        quotePerson="Mag. Noggler"
        quoteRole="Leitstelle Tirol"
        tags={['MOVETOS SET', 'MOVETOS Ops', '20 Kameras', '7 Tage']}
        image={`/images/ref-uci.jpg`}
      />
      <ReferenceCard
        name="Japan Tag Düsseldorf"
        category="Volksfest"
        visitors="800.000"
        highlight="Entlang der Rhein Promenade"
        quote="Ein live Bild, in Farbe, von allen Standorten und das bei der Besuchermenge, hatte ich nicht geglaubt."
        quotePerson=""
        quoteRole="Veranstalter"
        tags={['MOVETOS SET', 'MOVETOS Ops', '20 Kameras']}
      />
      <ReferenceCard
        name="Stoppelmarkt Vechta"
        category="Volksfest"
        visitors="600.000"
        highlight="Ohne Kabel und Traversen, mit Einbindung der Polizei"
        quote="Mit der Technik können wir beim nächsten Mal deutlich besser unser Personal planen."
        quotePerson="C. Thöle"
        quoteRole="Marktleiter"
        tags={['MOVETOS SET', 'MOVETOS Ops', '20 Kameras', '7 Tage']}
      />
    </div>

    <div class="text-center mt-10">
      <a href={`/referenzen/`} class="btn btn-ghost">Alle Referenzen ansehen &rarr;</a>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== CTA ===== -->
<section class="py-20 md:py-28 text-center">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label justify-center">Jetzt starten</div>
    <div class="section-title mx-auto" style="max-width: 540px;">
      30 Minuten. Ein Lagebild.<br>
      <span class="text-brand-orange">Ihre Entscheidung.</span>
    </div>
    <p class="section-desc text-center mx-auto mt-4" style="max-width: 460px;">
      In einer persönlichen Live-Demo zeigen wir Ihnen, wie MOVETOS Ops und MOVETOS SET bei Ihrem Event funktionieren — inklusive individueller Effizienzanalyse.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-8">
      <a href={`/ops/demo/`} class="btn btn-primary">Demo vereinbaren &rarr;</a>
      <a href="tel:+4981572934870" class="btn btn-ghost">&#9742; 08157 2934870</a>
    </div>
  </div>
</section>

</BaseLayout>
