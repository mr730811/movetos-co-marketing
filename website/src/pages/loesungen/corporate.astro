---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReferenceCard from '../../components/ReferenceCard.astro';
import ROICalculator from '../../components/ROICalculatorInline.astro';
---
<BaseLayout
  title="Sicherheitslösungen für Unternehmen | MOVETOS"
  description="Compliance-konforme Sicherheitslösungen für Firmenevents, Werkstage und sensible Unternehmensstandorte. KI-gestützte Lagebildführung und kabellose Infrastruktur."
>

<!-- ===== HERO ===== -->
<section class="relative pt-28 pb-16 md:pt-32 md:pb-20 overflow-hidden">
  <img src={`/images/tile-corporate.jpg`} alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
  <div class="absolute inset-0 bg-black/25 pointer-events-none"></div>
  <div class="max-w-[1200px] mx-auto px-6 relative">
    <div class="max-w-2xl bg-white/90 backdrop-blur-xl rounded-2xl p-8 md:p-12 shadow-lg border border-white/60">
      <div class="label mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-accent-blue"></span>
        Sicherheitslösungen
      </div>
      <h1 class="font-display text-4xl md:text-5xl font-800 tracking-tight leading-[1.08]">
        Sicherheit<br>
        <span class="text-accent-blue">für Unternehmen.</span>
      </h1>
      <p class="text-base md:text-lg text-text-secondary leading-relaxed mt-5 max-w-xl">
        Firmenevents, Werkstage, Betriebsversammlungen — wenn tausende Menschen auf sensiblem Gelände zusammenkommen, brauchen Sie mehr als einen Sicherheitsdienst. Sie brauchen ein System.
      </p>
      <div class="flex flex-wrap items-center gap-3 mt-8">
        <a href={`/ops/demo/`} class="btn btn-primary">Demo vereinbaren &rarr;</a>
        <a href={`/referenzen/`} class="btn btn-ghost bg-white/50">Referenzen ansehen</a>
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== HERAUSFORDERUNGEN ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">Die Herausforderung</div>
    <div class="section-title">Sensibles Gelände. Hohe Auflagen.<br><span class="text-brand-orange">Null Kompromisse.</span></div>
    <p class="section-desc">
      Corporate Events auf Werksgeländen, Firmenstandorten oder in Sonderbereichen erfordern besondere Sicherheitsstandards — und lückenlose Dokumentation. MOVETOS liefert beides.
    </p>

    <div class="grid md:grid-cols-3 gap-6 mt-14">
      {[
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>', title: 'PVA & Detektions-Gates', desc: 'Wer ist auf dem Gelände? Personenvereinzelungsanlagen (PVA) und Detektions-Gates (z. B. CEIA) mit Schnittstelle zum Zugangsmanagement — für lückenlose Kontrolle.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>', title: 'Compliance-Anforderungen', desc: 'HSE-Vorgaben, Werkschutzrichtlinien, behördliche Auflagen — alles muss dokumentiert und nachweisbar sein.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182"/></svg>', title: 'Temporärer Bedarf', desc: 'Ein Werksfest dauert einen Tag, nicht ein Jahr. Fest installierte Systeme sind Overkill, keine Infrastruktur ist ein Risiko.' },
      ].map(item => (
        <div class="reveal glass-card p-7">
          <div class="w-10 h-10 rounded-lg bg-brand-orange-glow flex items-center justify-center mb-3" set:html={item.icon}></div>
          <h3 class="font-display text-base font-bold mb-2">{item.title}</h3>
          <p class="text-sm text-text-secondary leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== LÖSUNG ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">Die Lösung</div>
    <div class="section-title">Mobile Sicherheitsinfrastruktur.<br><span class="text-accent-blue">Compliance inklusive.</span></div>
    <p class="section-desc">
      MOVETOS liefert ein temporäres Sicherheitssystem, das in wenigen Stunden steht und Enterprise-Anforderungen erfüllt — ohne permanente Installation.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mt-14">
      {[
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>', title: 'Echtzeit-Lagebild', desc: 'KI-gestützte Überwachung aller relevanten Bereiche. Personendichten, Zugangspunkte und Bewegungsmuster — alles auf einem Dashboard.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>', title: 'Automatische Compliance-Dokumentation', desc: 'Jede Maßnahme, jeder Alert, jede Entscheidung wird automatisch protokolliert. Export-fertig für HSE, Werkschutz und Behörden.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>', title: 'Perimeterschutz', desc: 'Kabellose Kamerasysteme überwachen den Randbereich des Geländes. Unbefugter Zutritt wird erkannt, kritische Zonen am Perimeter gesichert.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 0 1-1.44-4.282m3.102.069a18.03 18.03 0 0 1-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 0 1 8.835 2.535M10.34 6.66a23.847 23.847 0 0 0 8.835-2.535m0 0A23.74 23.74 0 0 0 18.795 3m.38 1.125a23.91 23.91 0 0 1 1.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 0 0 1.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 0 1 0 3.46"/></svg>', title: 'Gezielte Kommunikation', desc: 'Bereichsspezifische Durchsagen (BDS) und Notdurchsagen (NDS) — vom Lagebild direkt zur Ansprache. Ohne Funkgeräte-Chaos.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z"/></svg>', title: 'Aufbau in unter 5 Stunden', desc: 'Kabellose, netzautarke Infrastruktur. Plug & Play ohne Eingriff in bestehende IT-Systeme. Rückbau genauso schnell.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 0 0 2.25-2.25V6a2.25 2.25 0 0 0-2.25-2.25H6A2.25 2.25 0 0 0 3.75 6v2.25A2.25 2.25 0 0 0 6 10.5Zm0 9.75h2.25A2.25 2.25 0 0 0 10.5 18v-2.25a2.25 2.25 0 0 0-2.25-2.25H6a2.25 2.25 0 0 0-2.25 2.25V18A2.25 2.25 0 0 0 6 20.25Zm9.75-9.75H18a2.25 2.25 0 0 0 2.25-2.25V6A2.25 2.25 0 0 0 18 3.75h-2.25A2.25 2.25 0 0 0 13.5 6v2.25a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>', title: 'Integration & Zugangsmanagement', desc: 'MOVETOS Ops lässt sich in bestehende Werkschutz- und Sicherheitssysteme integrieren. Schnittstellen zu Zugangsmanagement, Detektions-Gates und Ticketsystemen.' },
      ].map(item => (
        <div class="reveal flex items-start gap-4 p-5 bg-surface border border-dark-border rounded-xl">
          <div class="shrink-0 mt-0.5" set:html={item.icon}></div>
          <div>
            <h3 class="font-display text-sm font-bold mb-1">{item.title}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== VORTEILE ===== -->
<section class="py-20 md:py-28 bg-dark-card">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">Ihre Vorteile</div>
    <div class="section-title">Warum Unternehmen<br><span class="text-accent-blue">MOVETOS wählen.</span></div>

    <div class="grid md:grid-cols-2 gap-6 mt-14">
      {[
        { title: 'Keine permanente Installation', desc: 'Mobile Infrastruktur, die nach dem Event wieder verschwindet. Kein Umbau, keine Genehmigungsverfahren für Festinstallation.' },
        { title: 'Enterprise-Grade Compliance', desc: 'Lückenlose Dokumentation aller sicherheitsrelevanten Maßnahmen. Audit-Trail für interne und externe Prüfungen.' },
        { title: 'HSE-Anforderungen erfüllen', desc: 'Automatische Frühwarnung bei kritischer Auslastung. Nachweisbare Sorgfaltspflicht für Veranstaltungsleiter.' },
        { title: 'Schnelle Entscheidungen', desc: 'Echtzeit-Lagebild statt Funksprüche. Datenbasierte Entscheidungen in Sekunden, nicht Minuten.' },
      ].map(item => (
        <div class="reveal flex items-start gap-3 p-5 bg-surface border border-dark-border rounded-xl">
          <span class="text-accent-blue text-xs mt-1">&#10003;</span>
          <div>
            <h3 class="font-display text-sm font-bold mb-1">{item.title}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== ROI CALCULATOR ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-10 items-center">
      <div>
        <div class="label">Ihr Mehrwert in Zahlen</div>
        <div class="section-title">Wie viel effizienter wird<br><span class="text-accent-blue">Ihr Corporate Event?</span></div>
        <p class="section-desc">
          Echtzeit-Lagebild statt Funksprüche: weniger Koordinationsaufwand, volle Compliance-Dokumentation. Rechnen Sie mit Ihren Zahlen.
        </p>
      </div>
      <div>
        <ROICalculator segment="corporate" />
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== REFERENZEN ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">Bewährt bei führenden Unternehmen</div>
    <div class="section-title">Corporate-Referenzen.</div>

    <div class="grid md:grid-cols-2 gap-5 mt-14 max-w-3xl">
      <ReferenceCard
        name="VW Familie Days Wolfsburg"
        category="Corporate"
        visitors="60.000"
        highlight="Großes Firmenareal ohne einen Meter Kabel voll im Blick"
        quote="Eine solche Fläche, in Echtzeit im Blick zu haben, ist was völlig neues für die Sicherheitsplanung."
        quotePerson="H. Holzemer"
        quoteRole="Fachplaner"
        tags={['MOVETOS SET', 'MOVETOS Ops', '60 Kameras']}
      />
      <ReferenceCard
        name="Pioniers Day Eurocopter / Airbus"
        category="Corporate"
        visitors="35.000"
        highlight="Gesamtes Firmengelände, 0 Meter Kabel"
        quote="Einfacher kann man Sicherheit kaum planen und umsetzen."
        quotePerson="M. Weiskopf"
        quoteRole="Fachplaner"
        tags={['BDS', '10x2 Lautsprecher']}
      />
      <ReferenceCard
        name="BMW Jubiläumstage"
        category="Corporate"
        visitors="45.000"
        highlight="Aufrüstung eines Werksgeländes"
        quote="Ein Werksgelände als Eventfläche ist eine Herausforderung und eine Besucherinformations-/Notfallbeschallung ist das Basic. Wichtig ist, dass dieses Basic verlässlich und einfach funktioniert und das kann MOVETOS gut."
        quotePerson="H. Schmitt"
        quoteRole="Veranstalter"
        tags={['BDS', '12x2 Lautsprecher + Licht']}
      />
      <ReferenceCard
        name="Tag der Bundeswehr"
        category="Corporate"
        visitors="500.000"
        highlight="15 Standorte, bis zu 45 ha Kasernenfläche ohne Kabel"
        quote="Noch nie hatten wir die kritische Liegenschaft so gut im Blick, wie jetzt."
        quotePerson="Projektleitung Bückeburg"
        quoteRole="Sicherheitsmanagement"
        tags={['MOVETOS SET', 'MOVETOS Ops', 'BDS', '15 Standorte']}
      />
    </div>

    <div class="text-center mt-10">
      <a href={`/referenzen/`} class="btn btn-ghost">Alle Referenzen ansehen &rarr;</a>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== CTA ===== -->
<section class="py-20 md:py-28 text-center">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label justify-center">Jetzt starten</div>
    <div class="section-title mx-auto" style="max-width: 540px;">
      Ihr nächstes Corporate Event.<br>
      <span class="text-accent-blue">Sicher geplant.</span>
    </div>
    <p class="section-desc text-center mx-auto mt-4" style="max-width: 460px;">
      In einer persönlichen Demo zeigen wir Ihnen, wie MOVETOS bei Ihrem nächsten Firmenevent funktioniert — zugeschnitten auf Ihre Anforderungen.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-8">
      <a href={`/ops/demo/`} class="btn btn-primary">Demo vereinbaren &rarr;</a>
      <a href="tel:+4981572934870" class="btn btn-ghost">&#9742; 08157 2934870</a>
    </div>
  </div>
</section>

</BaseLayout>
