---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SocialProofBar from '../../../components/SocialProofBar.astro';
import DashboardMockup from '../../../components/DashboardMockup.astro';
import FeatureCard from '../../../components/FeatureCard.astro';
import ReferenceCard from '../../../components/ReferenceCard.astro';

---
<BaseLayout
  title="TerrOps — Operations Intelligence Platform | MOVETOS"
  description="TerrOps is the AI-powered Operations Intelligence platform for situational awareness, crowd flow analysis, and operational control — for events, enterprises, and critical infrastructure."
>

<!-- ===== HERO ===== -->
<section class="relative pt-32 pb-20 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-brand-orange/[0.04] via-transparent to-transparent pointer-events-none"></div>

  <div class="max-w-[1200px] mx-auto px-6 relative">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <nav class="flex items-center gap-2 text-xs text-text-muted mb-6">
          <a  href={`/en/`} class="hover:text-text-secondary transition-colors">MOVETOS</a>
          <span>/</span>
          <a  href={`/en/terrops/`} class="hover:text-text-secondary transition-colors">Solutions</a>
          <span>/</span>
          <span class="text-brand-orange">TerrOps</span>
        </nav>

        <div class="label mb-4">
          <span class="live-dot"></span>
          Operations Intelligence Platform
        </div>

        <h1 class="font-display text-5xl md:text-6xl font-800 tracking-tight leading-[1.05]">
          Terr<span class="text-brand-orange">Ops</span><br>
          <span class="text-3xl md:text-4xl font-600 text-text-secondary leading-snug block mt-2">
            Know what's happening.<br>Control what matters.
          </span>
        </h1>

        <p class="text-base text-text-secondary leading-relaxed mt-6 max-w-lg">
          The AI platform for operational awareness. Real-time situational awareness, crowd flow analysis, and targeted control — for proactive decisions instead of flying blind.
        </p>

        <div class="flex flex-wrap gap-3 mt-8">
          <a  href={`/en/terrops/demo/`} class="btn btn-primary">Schedule Live Demo &rarr;</a>
          <a href="#how" class="btn btn-ghost">How It Works</a>
        </div>
      </div>

      <div class="reveal" style="transition-delay: 0.15s">
        <DashboardMockup />
      </div>
    </div>
  </div>
</section>

<!-- Social Proof -->
<div class="divider"></div>
<SocialProofBar lang="en" compact />
<div class="divider"></div>

<!-- ===== THE CHALLENGE ===== -->
<section class="relative py-20 md:py-28 overflow-hidden">
  <img src={`/images/crowd-atmosphere.jpg`} alt="" class="absolute inset-0 w-full h-full object-cover opacity-15" loading="lazy" />
  <div class="max-w-[1200px] mx-auto px-6 relative">
    <div class="max-w-2xl mx-auto text-center">
      <div class="label justify-center">The Challenge</div>
      <div class="section-title mx-auto mt-4">
        Those responsible for venues and people<br>need more than radio calls.
      </div>
      <p class="section-desc text-center mx-auto mt-4">
        Hundreds of decisions per hour — most based on gut feeling and fragmented information.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-4 mt-14 max-w-3xl mx-auto">
      {[
        { q: 'Where is the situation critical?', a: 'Radio call — when it\'s too late' },
        { q: 'How many people in the area?', a: 'Manual counting, time delay' },
        { q: 'Is the area at capacity?', a: 'Estimate from security staff' },
        { q: 'What happened 2 hours ago?', a: 'Nobody knows exactly' },
      ].map((item, i) => (
        <div class="reveal glass-card p-5" style={`transition-delay: ${i * 0.08}s`}>
          <div class="text-sm font-semibold text-text-primary mb-1">{item.q}</div>
          <div class="text-xs text-text-muted flex items-center gap-2">
            <span class="text-accent-red">&#10005;</span>
            {item.a}
          </div>
        </div>
      ))}
    </div>

    <div class="reveal text-center mt-10">
      <p class="text-lg font-display font-semibold text-brand-orange">
        TerrOps puts an end to flying blind.
      </p>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== THE TERROPS LOOP ===== -->
<section class="py-20 md:py-28 bg-dark-card" id="how">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">How It Works</div>
    <div class="section-title">From detection to control<br>— in real time.</div>
    <p class="section-desc">
      TerrOps closes the loop between detection, assessment, and targeted action — automatically or confirmed by the operator.
    </p>

    <div class="grid md:grid-cols-3 gap-0 mt-14 relative">
      <!-- Connection line -->
      <div class="hidden md:block absolute top-[56px] left-[16.66%] right-[16.66%] h-[2px] bg-gradient-to-r from-brand-orange via-accent-blue to-accent-green opacity-30"></div>

      {[
        {
          step: '01',
          icon: '&#128200;',
          title: 'Detect',
          desc: 'TerrOps captures people counts, capacity levels, and movement patterns across all camera locations — continuously and in real time.',
          badge: 'bg-gradient-to-br from-brand-orange/15 to-brand-orange/5 border-brand-orange/20',
        },
        {
          step: '02',
          icon: '&#129504;',
          title: 'Assess',
          desc: 'The platform automatically evaluates the situation based on configurable thresholds and provides the operations team with clear action recommendations.',
          badge: 'bg-gradient-to-br from-accent-blue/15 to-accent-blue/5 border-accent-blue/20',
        },
        {
          step: '03',
          icon: '&#128227;',
          title: 'Control',
          desc: 'When needed, TerrOps triggers targeted measures — from area-specific announcements to evacuation communications. Automatically or via operator.',
          badge: 'bg-gradient-to-br from-accent-green/15 to-accent-green/5 border-accent-green/20',
        },
      ].map((item, i) => (
        <div class="reveal text-center px-6" style={`transition-delay: ${i * 0.12}s`}>
          <div class="font-mono text-[10px] text-text-muted tracking-wider mb-2">STEP {item.step}</div>
          <div class:list={["w-14 h-14 mx-auto mb-5 rounded-2xl flex items-center justify-center text-2xl border relative z-10", item.badge]}>
            <Fragment set:html={item.icon} />
          </div>
          <h3 class="font-display text-lg font-semibold mb-2">{item.title}</h3>
          <p class="text-sm text-text-secondary leading-relaxed max-w-[280px] mx-auto">{item.desc}</p>
        </div>
      ))}
    </div>

    <div class="reveal text-center mt-12 p-5 bg-surface border border-dark-border rounded-xl max-w-2xl mx-auto">
      <p class="text-sm text-text-secondary">
        <strong class="text-brand-orange">The key:</strong> TerrOps connects detection and control into a closed-loop system. No media breaks. No delays. Your team stays in control.
      </p>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== SAFETY INTELLIGENCE ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">Safety Intelligence</div>
    <div class="section-title">Safety is not an add-on —<br><span class="text-brand-orange">it's built in.</span></div>
    <p class="section-desc">
      TerrOps detects critical situations before they escalate. MOVETOS SET enables immediate response — targeted, documented, traceable.
    </p>

    <div class="grid md:grid-cols-3 gap-5 mt-14">
      <div class="reveal glass-card p-7">
        <div class="text-2xl mb-4">&#9888;</div>
        <h3 class="font-display text-base font-bold mb-2">Early Warning System</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          Automatic alerts when crowd density increases. Configurable thresholds by zone. Graduated escalation with action recommendations.
        </p>
      </div>
      <div class="reveal glass-card p-7" style="transition-delay: 0.08s">
        <div class="text-2xl mb-4">&#128227;</div>
        <h3 class="font-display text-base font-bold mb-2">Evacuation Support</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          Targeted announcements to affected areas. Zone-based communication for orderly evacuation. Situational overview for incident command and emergency services.
        </p>
      </div>
      <div class="reveal glass-card p-7" style="transition-delay: 0.16s">
        <div class="text-2xl mb-4">&#128196;</div>
        <h3 class="font-display text-base font-bold mb-2">Complete Audit Trail</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          Every measure is automatically documented. Complete audit trail for authorities. Simplified approval processes through reliable documentation.
        </p>
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== THE VALUE ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">The Value</div>
    <div class="section-title">What TerrOps means for<br>your operations.</div>
    <p class="section-desc">
      It's not about features — it's about results. TerrOps transforms how you run your operations.
    </p>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 mt-14">
      <div class="reveal glass-card p-7">
        <div class="text-2xl mb-4">&#128176;</div>
        <h3 class="font-display text-base font-bold mb-2">Deploy Staff More Efficiently</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          Direct security personnel, paramedics, and stewards precisely where they're needed. Reduce staffing costs through data-driven deployment planning.
        </p>
      </div>
      <div class="reveal glass-card p-7" style="transition-delay: 0.08s">
        <div class="text-2xl mb-4">&#11088;</div>
        <h3 class="font-display text-base font-bold mb-2">Optimize Processes</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          Avoid bottlenecks, improve workflows, deploy resources where needed. Early relief of critical areas.
        </p>
      </div>
      <div class="reveal glass-card p-7" style="transition-delay: 0.16s">
        <div class="text-2xl mb-4">&#9889;</div>
        <h3 class="font-display text-base font-bold mb-2">Decide Faster</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          Real-time situational awareness instead of radio calls. Detect and defuse critical situations before they escalate.
        </p>
      </div>
      <div class="reveal glass-card p-7" style="transition-delay: 0.24s">
        <div class="text-2xl mb-4">&#128196;</div>
        <h3 class="font-display text-base font-bold mb-2">Built-in Compliance</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          Complete documentation runs automatically. Safety certifications for approval authorities at the push of a button.
        </p>
      </div>
      <div class="reveal glass-card p-7" style="transition-delay: 0.32s">
        <div class="text-2xl mb-4">&#129309;</div>
        <h3 class="font-display text-base font-bold mb-2">Empower Your Team</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          TerrOps is the co-pilot for your security and operations team. Better information for better decisions — the human stays in control.
        </p>
      </div>
      <div class="reveal glass-card p-7" style="transition-delay: 0.4s">
        <div class="text-2xl mb-4">&#128274;</div>
        <h3 class="font-display text-base font-bold mb-2">Privacy by Design</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          No facial recognition. Configurable privacy zones. Automatic image masking. Data protection is an architectural principle, not an add-on module.
        </p>
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== TERROPS FOR YOUR INDUSTRY ===== -->
<section class="py-20 md:py-28 bg-dark-card">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">TerrOps for Your Industry</div>
    <div class="section-title">One system.<br>Three areas of application.</div>
    <p class="section-desc">
      TerrOps adapts to your scenario — whether large-scale event, corporate event, or critical infrastructure.
    </p>

    <div class="grid md:grid-cols-3 gap-6 mt-14">
      <a href={`/en/solutions/events/`} class="reveal glass-card p-7 border-t-2 border-t-accent-green group no-underline hover:border-accent-green/40 transition-all">
        <div class="w-10 h-10 rounded-xl bg-accent-green-dim flex items-center justify-center text-lg mb-4">&#128737;</div>
        <h3 class="font-display text-base font-bold text-text-primary group-hover:text-accent-green transition-colors mb-2">Events & Festivals</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          Manage crowd flows in real time, efficiently coordinate response teams, and ensure safety.
        </p>
        <span class="inline-flex items-center gap-1 text-sm text-accent-green font-medium mt-4 group-hover:translate-x-1 transition-transform">Learn more &rarr;</span>
      </a>

      <a href={`/en/solutions/corporate/`} class="reveal glass-card p-7 border-t-2 border-t-accent-blue group no-underline hover:border-accent-blue/40 transition-all" style="transition-delay: 0.1s">
        <div class="w-10 h-10 rounded-xl bg-accent-blue-dim flex items-center justify-center text-lg mb-4">&#127970;</div>
        <h3 class="font-display text-base font-bold text-text-primary group-hover:text-accent-blue transition-colors mb-2">Corporate</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          Compliance-ready monitoring for corporate events and plant security. Complete documentation for HSE and authorities.
        </p>
        <span class="inline-flex items-center gap-1 text-sm text-accent-blue font-medium mt-4 group-hover:translate-x-1 transition-transform">Learn more &rarr;</span>
      </a>

      <a href={`/en/solutions/critical-infrastructure/`} class="reveal glass-card p-7 border-t-2 border-t-brand-orange group no-underline hover:border-brand-orange/40 transition-all" style="transition-delay: 0.2s">
        <div class="w-10 h-10 rounded-xl bg-brand-orange-glow flex items-center justify-center text-lg mb-4">&#128274;</div>
        <h3 class="font-display text-base font-bold text-text-primary group-hover:text-brand-orange transition-colors mb-2">Critical Infrastructure</h3>
        <p class="text-sm text-text-secondary leading-relaxed">
          24/7 situational awareness for perimeter protection and operational control. Integration into existing command center systems.
        </p>
        <span class="inline-flex items-center gap-1 text-sm text-brand-orange font-medium mt-4 group-hover:translate-x-1 transition-transform">Learn more &rarr;</span>
      </a>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== FEATURES ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">Features</div>
    <div class="section-title">Your early warning system for<br>ongoing operations.</div>
    <p class="section-desc">
      Pre-configured based on international operational standards — ready to deploy, individually customizable.
    </p>

    <div class="grid md:grid-cols-2 gap-3 mt-14">
      <FeatureCard icon="&#128200;" title="Real-time People Analytics" description="People counts, capacity levels, and dwell times across all areas — continuously and in real time." color="green" />
      <FeatureCard icon="&#127758;" title="Crowd Flow Visualization" description="See where people are moving, where congestion occurs, and where relief is possible." color="blue" />
      <FeatureCard icon="&#128227;" title="Targeted Control & Announcements" description="Area-specific announcements via MOVETOS BDS speakers. The right information at the right place." color="orange" />
      <FeatureCard icon="&#128506;" title="Operational Real-time Cockpit" description="Your entire site on an interactive map. All KPIs, all systems, one view." color="blue" />
      <FeatureCard icon="&#128196;" title="Documentation That Runs Automatically" description="Automatic logging of all events. Audit trail, export functions, authority reports." color="yellow" />
      <FeatureCard icon="&#128274;" title="Privacy as a Design Principle" description="No facial recognition. Privacy zones. Automatic masking. GDPR-compliant by design." color="red" />
      <FeatureCard icon="&#128680;" title="Safety Alerts" description="Automatic warnings at critical crowd density. Graduated escalation with action recommendations." color="red" />
      <FeatureCard icon="&#128260;" title="Interfaces & Integration" description="Integration of detection gates (CEIA), people counting (manual clickers), ticket capture, and access management." color="purple" />
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== INTEGRATION WITH MOVETOS HARDWARE ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">Seamless Integration</div>
    <div class="section-title">Software and hardware<br>as one system.</div>
    <p class="section-desc">TerrOps reaches its full potential in combination with the wireless MOVETOS infrastructure.</p>

    <div class="grid lg:grid-cols-[1fr_auto_1fr] gap-6 items-center mt-14">
      <div class="reveal glass-card p-7">
        <div class="flex items-center gap-3 mb-3">
          <h3 class="font-display text-lg font-bold">TerrOps</h3>
          <span class="font-mono text-[9px] px-2 py-0.5 bg-accent-blue-dim text-accent-blue rounded font-medium">SOFTWARE</span>
        </div>
        <p class="text-sm text-text-secondary leading-relaxed mb-4">AI people analytics, operations dashboard, PA system control, compliance documentation.</p>
        <div class="flex flex-col gap-1.5">
          {['Real-time analysis of all camera streams', 'Automatic action recommendations', 'Interactive situational map', 'Role-based team management', 'Audit trail & documentation'].map(f => (
            <div class="flex items-center gap-2 text-xs text-text-secondary">
              <span class="text-accent-green text-xs">&#10003;</span> {f}
            </div>
          ))}
        </div>
      </div>

      <div class="flex flex-col items-center gap-2 py-4 lg:py-0">
        <span class="font-mono text-[9px] text-text-muted uppercase tracking-wider">API</span>
        <div class="w-16 h-0.5 bg-gradient-to-r from-accent-blue to-brand-orange rounded lg:w-0.5 lg:h-16"></div>
        <span class="font-mono text-[9px] text-text-muted uppercase tracking-wider">MESH</span>
      </div>

      <div class="reveal glass-card overflow-hidden" style="transition-delay: 0.1s">
        <img src={`/images/set-mast.jpg`} alt="MOVETOS SET mast system in operation" class="w-full h-44 object-cover" loading="lazy" />
        <div class="p-7">
        <div class="flex items-center gap-3 mb-3">
          <h3 class="font-display text-lg font-bold">MOVETOS SET</h3>
          <span class="font-mono text-[9px] px-2 py-0.5 bg-brand-orange-glow text-brand-orange rounded font-medium">HARDWARE</span>
        </div>
        <p class="text-sm text-text-secondary leading-relaxed mb-4">10 mast systems (5.5 m) with cameras, LED lighting, speakers, and OCC — wireless, grid-independent, Plug & Play.</p>
        <div class="flex flex-col gap-1.5">
          {['10 mast systems with cameras, LED, and speakers', 'Public Address System (BDS) — individual, wireless', 'Operation Control Centre (OCC)', 'Grid & power independent with dedicated data transmission', 'Plug & Play in under 5 hours'].map(f => (
            <div class="flex items-center gap-2 text-xs text-text-secondary">
              <span class="text-accent-green text-xs">&#10003;</span> {f}
            </div>
          ))}
        </div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== COMPLIANCE ===== -->
<section class="py-16">
  <div class="max-w-[1200px] mx-auto px-6">
    <p class="font-mono text-[10px] font-medium uppercase tracking-[2px] text-text-muted text-center mb-5">
      Built-in, not bolted on
    </p>
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-3">
      {[
        { code: 'MVStättVO', name: 'Assembly Venues' },
        { code: 'DIN EN 13200', name: 'Spectator Facilities' },
        { code: 'EN 50518', name: 'Alarm Receiving Centres' },
        { code: 'VdS 2366', name: 'Video Surveillance' },
        { code: 'ISO 22313', name: 'Business Continuity' },
        { code: 'DIN 14675', name: 'Fire Alarm Systems' },
        { code: 'GDPR', name: 'Data Protection' },
      ].map((norm, i) => (
        <div class="reveal bg-dark-card border border-dark-border rounded-xl py-5 px-4 text-center" style={`transition-delay: ${i * 0.06}s`}>
          <div class="font-mono text-sm font-medium text-text-primary mb-1">{norm.code}</div>
          <div class="text-[10px] text-text-muted">{norm.name}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== REFERENCES ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">Proven in Practice</div>
    <div class="section-title">TerrOps in action.</div>
    <p class="section-desc">From festivals to corporate events to critical infrastructure — TerrOps is deployed where it matters.</p>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5 mt-14">
      <ReferenceCard
        name="BMW Motorrad Days"
        category="Corporate"
        visitors="135,000"
        highlight="Event delivered despite 15% staff shortfall on event day"
        quote="Security at this technical level is convincing."
        quotePerson="H. Schmitt"
        quoteRole="Event Organizer"
        tags={['MOVETOS SET', 'TerrOps', '20 Cameras', '3x']}
        image={`/images/ref-bmw.jpg`}
      />
      <ReferenceCard
        name="VW Family Days Wolfsburg"
        category="Corporate"
        visitors="60,000"
        highlight="Entire corporate campus covered without a single meter of cable"
        quote="Having such an area in real-time view is something completely new for security planning."
        quotePerson="H. Holzemer"
        quoteRole="Security Planner"
        tags={['MOVETOS SET', 'TerrOps', '60 Cameras']}
        image={`/images/ref-vw.jpg`}
      />
      <ReferenceCard
        name="UCI Road World Championships"
        category="Sports Event"
        visitors="1.15M"
        highlight="Entire city center covered wirelessly, integrated with Tyrol Command Center"
        quote="Security has never been this easy and reliable."
        quotePerson="Mag. Noggler"
        quoteRole="Tyrol Command Center"
        tags={['MOVETOS SET', 'TerrOps', '20 Cameras', '7 Days']}
        image={`/images/ref-uci.jpg`}
      />
      <ReferenceCard
        name="Munich Airport"
        category="CRITIS"
        visitors="Ongoing"
        highlight="Data transmission across the entire airfield"
        quote="Operational in two days — we never thought that was possible, with data transmission across the entire airfield."
        quotePerson="R. Götze"
        quoteRole="Airport"
        tags={['TerrOps', 'CRITIS', '40 Cameras', '24/7']}
        image={`/images/ref-muc.jpg`}
      />
    </div>

    <div class="text-center mt-10">
      <a  href={`/en/references/`} class="btn btn-ghost">View all references &rarr;</a>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== HARDWARE BANNER ===== -->
<section class="py-14">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="reveal bg-gradient-to-br from-brand-orange/[0.06] to-brand-orange/[0.02] border border-brand-orange/10 rounded-2xl p-8 md:p-10 flex flex-col md:flex-row items-center justify-between gap-8">
      <div>
        <h3 class="font-display text-xl font-bold mb-2">No MOVETOS hardware yet?</h3>
        <p class="text-sm text-text-secondary max-w-lg">
          TerrOps reaches its full potential in combination with the MOVETOS SET system — wireless, grid-independent, operational in under 5 hours.
        </p>
      </div>
      <a  href={`/en/infrastructure/`} class="btn btn-primary btn-sm whitespace-nowrap">Discover MOVETOS SET &rarr;</a>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== CTA ===== -->
<section class="py-20 md:py-28 text-center">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label justify-center">Get Started</div>
    <div class="section-title mx-auto" style="max-width: 540px;">
      Experience TerrOps<br>
