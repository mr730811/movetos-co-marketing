---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="About MOVETOS — Smart Infrastructure Made in Germany"
  description="MOVETOS Germany GmbH develops wireless infrastructure systems and AI software for large-scale events. Located in Pöcking at Lake Starnberg."
  lang="en"
>

<section class="pt-32 pb-20">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label mb-4">About MOVETOS</div>
    <h1 class="section-title">
      We make events possible<br>
      that couldn't happen <span class="text-brand-orange">without us.</span>
    </h1>
    <p class="section-desc mt-4 max-w-2xl">
      MOVETOS Germany GmbH develops the mobile all-in-one solution for crowd management: AI-powered software and wireless, grid-independent infrastructure — for events and critical sites, wherever no permanent infrastructure exists.
    </p>
  </div>
</section>

<div class="divider"></div>

<!-- Vision -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div>
        <div class="label">Our Vision</div>
        <div class="section-title mt-4">Operations Intelligence<br>for every event.</div>
        <p class="text-sm text-text-secondary leading-relaxed mt-6">
          We believe that great events deserve a great operational foundation. That's why we develop technology that gives operators the tools to steer proactively instead of reacting blindly.
        </p>
        <p class="text-sm text-text-secondary leading-relaxed mt-4">
          Our approach: hardware and software as one system. MOVETOS SET delivers the physical infrastructure — wireless, grid-independent, set up in hours. TerrOps delivers the intelligence — AI-powered visitor analysis, real-time situational awareness, and built-in compliance.
        </p>
      </div>
      <div class="reveal glass-card p-8">
        <div class="grid grid-cols-2 gap-6">
          {[
            { value: '2017', label: 'Founded' },
            { value: 'Pöcking', label: 'at Lake Starnberg' },
            { value: '12.7M+', label: 'Visitors' },
            { value: '100%', label: 'Made in Germany' },
          ].map(stat => (
            <div class="text-center">
              <div class="font-display text-2xl font-800 text-brand-orange">{stat.value}</div>
              <div class="text-xs text-text-muted mt-1">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- Values -->
<section class="py-20 md:py-28 bg-dark-card">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">What Drives Us</div>
    <div class="section-title mt-4">Our Principles.</div>

    <div class="grid md:grid-cols-3 gap-6 mt-14">
      {[
        {
          icon: '&#128161;',
          title: 'Practice-oriented',
          desc: 'Our technology is born from real requirements of real events — not from a desk. Every feature originates from a concrete operational challenge.',
        },
        {
          icon: '&#129309;',
          title: 'Partnership-driven',
          desc: 'We see ourselves as part of our customers\' operations team. Not as a vendor, but as a partner for operational success — before, during, and after the event.',
        },
        {
          icon: '&#128187;',
          title: 'Made in Germany',
          desc: 'Development, manufacturing, and support from Pöcking at Lake Starnberg. German engineering meets modern software development.',
        },
      ].map((item, i) => (
        <div class="reveal p-6" style={`transition-delay: ${i * 0.1}s`}>
          <div class="text-2xl mb-3"><Fragment set:html={item.icon} /></div>
          <h3 class="font-display text-lg font-bold mb-2">{item.title}</h3>
          <p class="text-sm text-text-secondary leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- Location -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6 text-center">
    <div class="label justify-center">Location</div>
    <div class="section-title mt-4 mx-auto">Pöcking at Lake Starnberg.</div>
    <p class="section-desc text-center mx-auto mt-4">
      MOVETOS Germany GmbH<br>
      Feldafinger Str. 5<br>
      82343 Pöcking
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-8">
      <a  href={`${import.meta.env.BASE_URL}/en/contact/`} class="btn btn-primary">Get in Touch &rarr;</a>
      <a href="tel:+4981572934870" class="btn btn-ghost">&#9742; 08157 2934870</a>
    </div>
  </div>
</section>

</BaseLayout>
