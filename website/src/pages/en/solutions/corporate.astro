---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ReferenceCard from '../../../components/ReferenceCard.astro';
import ROICalculator from '../../../components/ROICalculatorInline.astro';
---
<BaseLayout
  title="Security Solutions for Enterprises | MOVETOS"
  description="Compliance-ready security solutions for corporate events, factory days and sensitive enterprise locations. AI-powered situational awareness and wireless infrastructure."
  lang="en"
>

<!-- ===== HERO ===== -->
<section class="relative pt-28 pb-16 md:pt-32 md:pb-20 overflow-hidden">
  <img src={`/images/tile-corporate.jpg`} alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
  <div class="absolute inset-0 bg-black/25 pointer-events-none"></div>
  <div class="max-w-[1200px] mx-auto px-6 relative">
    <div class="max-w-2xl bg-white/90 backdrop-blur-xl rounded-2xl p-8 md:p-12 shadow-lg border border-white/60">
      <div class="label mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-accent-blue"></span>
        Security Solutions
      </div>
      <h1 class="font-display text-4xl md:text-5xl font-800 tracking-tight leading-[1.08]">
        Security<br>
        <span class="text-accent-blue">for Enterprises.</span>
      </h1>
      <p class="text-base md:text-lg text-text-secondary leading-relaxed mt-5 max-w-xl">
        Corporate events, factory days, company gatherings — when thousands of people come together on sensitive premises, you need more than a security service. You need a system.
      </p>
      <div class="flex flex-wrap items-center gap-3 mt-8">
        <a href={`/en/ops/demo/`} class="btn btn-primary">Schedule Demo &rarr;</a>
        <a href={`/en/references/`} class="btn btn-ghost bg-white/50">View References</a>
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== CHALLENGES ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">The Challenge</div>
    <div class="section-title">Sensitive venues. High standards.<br><span class="text-brand-orange">Zero compromises.</span></div>
    <p class="section-desc">
      Corporate events on factory premises, company sites or in restricted areas require special safety standards — and seamless documentation. MOVETOS delivers both.
    </p>

    <div class="grid md:grid-cols-3 gap-6 mt-14">
      {[
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>', title: 'PVA & Detection Gates', desc: 'Who is on the premises? Personnel access gates (PVA) and detection gates (e.g. CEIA) with interface to access management — for seamless control.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>', title: 'Compliance Requirements', desc: 'HSE regulations, plant security guidelines, regulatory requirements — everything must be documented and verifiable.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182"/></svg>', title: 'Temporary Needs', desc: 'A factory fair lasts one day, not one year. Permanently installed systems are overkill, no infrastructure is a risk.' },
      ].map(item => (
        <div class="reveal glass-card p-7">
          <div class="w-10 h-10 rounded-lg bg-brand-orange-glow flex items-center justify-center mb-3" set:html={item.icon}></div>
          <h3 class="font-display text-base font-bold mb-2">{item.title}</h3>
          <p class="text-sm text-text-secondary leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== SOLUTION ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">The Solution</div>
    <div class="section-title">Mobile Security Infrastructure.<br><span class="text-accent-blue">Compliance included.</span></div>
    <p class="section-desc">
      MOVETOS delivers a temporary security system that is set up in just a few hours and meets enterprise requirements — without permanent installation.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mt-14">
      {[
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>', title: 'Real-time Situational Picture', desc: 'AI-powered monitoring of all relevant areas. Crowd densities, access points and movement patterns — all on one dashboard.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>', title: 'Automatic Compliance Documentation', desc: 'Every measure, every alert, every decision is automatically logged. Export-ready for HSE, plant security and authorities.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>', title: 'Perimeter Protection', desc: 'Wireless camera systems monitor the perimeter of the premises. Unauthorized access is detected, critical perimeter zones are secured.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 0 1-1.44-4.282m3.102.069a18.03 18.03 0 0 1-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 0 1 8.835 2.535M10.34 6.66a23.847 23.847 0 0 0 8.835-2.535m0 0A23.74 23.74 0 0 0 18.795 3m.38 1.125a23.91 23.91 0 0 1 1.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 0 0 1.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 0 1 0 3.46"/></svg>', title: 'Targeted Communication', desc: 'Area-specific broadcasts (BDS) and emergency broadcasts (NDS) — from the situational picture directly to the announcement. Without radio chaos.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z"/></svg>', title: 'Setup in Under 5 Hours', desc: 'Wireless, off-grid infrastructure. Plug & play without interfering with existing IT systems. Teardown just as fast.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 0 0 2.25-2.25V6a2.25 2.25 0 0 0-2.25-2.25H6A2.25 2.25 0 0 0 3.75 6v2.25A2.25 2.25 0 0 0 6 10.5Zm0 9.75h2.25A2.25 2.25 0 0 0 10.5 18v-2.25a2.25 2.25 0 0 0-2.25-2.25H6a2.25 2.25 0 0 0-2.25 2.25V18A2.25 2.25 0 0 0 6 20.25Zm9.75-9.75H18a2.25 2.25 0 0 0 2.25-2.25V6A2.25 2.25 0 0 0 18 3.75h-2.25A2.25 2.25 0 0 0 13.5 6v2.25a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>', title: 'Integration & Access Management', desc: 'MOVETOS Ops integrates with existing plant security systems. Interfaces to access management, detection gates and ticketing systems.' },
      ].map(item => (
        <div class="reveal flex items-start gap-4 p-5 bg-surface border border-dark-border rounded-xl">
          <div class="shrink-0 mt-0.5" set:html={item.icon}></div>
          <div>
            <h3 class="font-display text-sm font-bold mb-1">{item.title}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== ADVANTAGES ===== -->
<section class="py-20 md:py-28 bg-dark-card">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">Your Advantages</div>
    <div class="section-title">Why enterprises choose<br><span class="text-accent-blue">MOVETOS.</span></div>

    <div class="grid md:grid-cols-2 gap-6 mt-14">
      {[
        { title: 'No permanent installation', desc: 'Mobile infrastructure that disappears after the event. No renovations, no permit procedures for permanent installations.' },
        { title: 'Enterprise-Grade Compliance', desc: 'Seamless documentation of all safety-relevant measures. Audit trail for internal and external reviews.' },
        { title: 'Meeting HSE requirements', desc: 'Automatic early warning at critical capacity. Demonstrable duty of care for event managers.' },
        { title: 'Fast decisions', desc: 'Real-time situational picture instead of radio calls. Data-driven decisions in seconds, not minutes.' },
      ].map(item => (
        <div class="reveal flex items-start gap-3 p-5 bg-surface border border-dark-border rounded-xl">
          <span class="text-accent-blue text-xs mt-1">&#10003;</span>
          <div>
            <h3 class="font-display text-sm font-bold mb-1">{item.title}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== ROI CALCULATOR ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-10 items-center">
      <div>
        <div class="label">Your ROI in Numbers</div>
        <div class="section-title">How much more efficient<br><span class="text-accent-blue">is your corporate event?</span></div>
        <p class="section-desc">
          Real-time situational awareness instead of radio calls: less coordination overhead, full compliance documentation. Calculate with your numbers.
        </p>
      </div>
      <div>
        <ROICalculator segment="corporate" lang="en" />
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== REFERENCES ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">Trusted by leading enterprises</div>
    <div class="section-title">Corporate References.</div>

    <div class="grid md:grid-cols-2 gap-5 mt-14 max-w-3xl">
      <ReferenceCard
        name="VW Family Days Wolfsburg"
        category="Corporate"
        visitors="60,000"
        highlight="Large corporate campus fully monitored without a single meter of cable"
        quote="Eine solche Fläche, in Echtzeit im Blick zu haben, ist was völlig neues für die Sicherheitsplanung."
        quotePerson="H. Holzemer"
        quoteRole="Security Planner"
        tags={['MOVETOS SET', 'MOVETOS Ops', '60 Cameras']}
      />
      <ReferenceCard
        name="Pioneers Day Eurocopter / Airbus"
        category="Corporate"
        visitors="35,000"
        highlight="Entire corporate campus, 0 meters of cable"
        quote="Einfacher kann man Sicherheit kaum planen und umsetzen."
        quotePerson="M. Weiskopf"
        quoteRole="Security Planner"
        tags={['BDS', '10x2 Speakers']}
      />
      <ReferenceCard
        name="BMW Anniversary Days"
        category="Corporate"
        visitors="45,000"
        highlight="Upgrading a factory site"
        quote="Ein Werksgelände als Eventfläche ist eine Herausforderung und eine Besucherinformations-/Notfallbeschallung ist das Basic. Wichtig ist, dass dieses Basic verlässlich und einfach funktioniert und das kann MOVETOS gut."
        quotePerson="H. Schmitt"
        quoteRole="Organizer"
        tags={['BDS', '12x2 Speakers + Lighting']}
      />
      <ReferenceCard
        name="Tag der Bundeswehr"
        category="Corporate"
        visitors="500,000"
        highlight="15 locations, up to 45 hectares of barracks without cables"
        quote="Noch nie hatten wir die kritische Liegenschaft so gut im Blick, wie jetzt."
        quotePerson="Project Lead Bückeburg"
        quoteRole="Security Management"
        tags={['MOVETOS SET', 'MOVETOS Ops', 'BDS', '15 Locations']}
      />
    </div>

    <div class="text-center mt-10">
      <a href={`/en/references/`} class="btn btn-ghost">View All References &rarr;</a>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== CTA ===== -->
<section class="py-20 md:py-28 text-center">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label justify-center">Get Started</div>
    <div class="section-title mx-auto" style="max-width: 540px;">
      Your next corporate event.<br>
      <span class="text-accent-blue">Securely planned.</span>
    </div>
    <p class="section-desc text-center mx-auto mt-4" style="max-width: 460px;">
      In a personal demo, we show you how MOVETOS works at your next corporate event — tailored to your requirements.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-8">
      <a href={`/en/ops/demo/`} class="btn btn-primary">Schedule Demo &rarr;</a>
      <a href="tel:+4981572934870" class="btn btn-ghost">&#9742; 08157 2934870</a>
    </div>
  </div>
</section>

</BaseLayout>
