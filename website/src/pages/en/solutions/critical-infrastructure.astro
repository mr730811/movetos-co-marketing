---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ReferenceCard from '../../../components/ReferenceCard.astro';
import ROICalculator from '../../../components/ROICalculatorInline.astro';
---
<BaseLayout
  title="Perimeter Protection & Situational Awareness for Critical Infrastructure | MOVETOS"
  description="24/7 situational awareness and perimeter protection for critical infrastructure. AI-powered monitoring for airports, energy providers and sensitive facilities. Mobile or permanent solution."
  lang="en"
>

<!-- ===== HERO ===== -->
<section class="relative pt-28 pb-16 md:pt-32 md:pb-20 overflow-hidden">
  <img src={`/images/tile-kritis.jpg`} alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
  <div class="absolute inset-0 bg-black/25 pointer-events-none"></div>
  <div class="max-w-[1200px] mx-auto px-6 relative">
    <div class="max-w-2xl bg-white/90 backdrop-blur-xl rounded-2xl p-8 md:p-12 shadow-lg border border-white/60">
      <div class="label mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-orange"></span>
        Critical Infrastructure
      </div>
      <h1 class="font-display text-4xl md:text-5xl font-800 tracking-tight leading-[1.08]">
        Perimeter Protection &<br>
        <span class="text-brand-orange">Situational Awareness.</span>
      </h1>
      <p class="text-base md:text-lg text-text-secondary leading-relaxed mt-5 max-w-xl">
        AI-powered monitoring and real-time situational awareness for airports, energy providers and critical infrastructure. Mobile or permanent. 24/7. Made in Germany.
      </p>
      <div class="flex flex-wrap items-center gap-3 mt-8">
        <a href={`/en/terrops/demo/`} class="btn btn-primary">Schedule Consultation &rarr;</a>
        <a href="tel:+4981572934870" class="btn btn-ghost bg-white/50">&#9742; 08157 2934870</a>
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== CHALLENGES ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">The Challenge</div>
    <div class="section-title">Protecting critical infrastructure.<br><span class="text-brand-orange">Around the clock.</span></div>
    <p class="section-desc">
      Airports, energy providers, data centers — critical infrastructure operators face special requirements for perimeter protection and situational awareness. MOVETOS delivers the technology for it.
    </p>

    <div class="grid md:grid-cols-3 gap-6 mt-14">
      {[
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>', title: 'Perimeter Security', desc: 'Extensive premises, numerous access points, various security zones — everything must be monitored and documented.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>', title: '24/7 Operations', desc: 'Critical infrastructure has no opening hours. Monitoring systems must operate reliably around the clock.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/></svg>', title: 'Real-time Situational Awareness', desc: 'In an emergency, seconds count. Operational decisions require a current, complete situational picture — not radio calls.' },
      ].map(item => (
        <div class="reveal glass-card p-7">
          <div class="w-10 h-10 rounded-lg bg-brand-orange-glow flex items-center justify-center mb-3" set:html={item.icon}></div>
          <h3 class="font-display text-base font-bold mb-2">{item.title}</h3>
          <p class="text-sm text-text-secondary leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== SOLUTION ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">The Solution</div>
    <div class="section-title">Intelligent situational awareness.<br><span class="text-brand-orange">From camera to action.</span></div>
    <p class="section-desc">
      MOVETOS Ops delivers an AI-powered real-time situational picture with automatic anomaly detection. MOVETOS SET supplements the wireless infrastructure as needed — rapidly deployable, immediately operational.
    </p>

    <div class="grid md:grid-cols-2 gap-6 mt-14">
      {[
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>', title: 'AI-powered Video Analysis', desc: 'Automatic detection of anomalies, crowd densities and movement patterns. Integration of existing camera systems or supplementation with MOVETOS SET.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z"/></svg>', title: 'Real-time Situational Picture', desc: 'Map-based overview of all monitored areas. Zones, cameras, alerts and measures — all on one screen.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0"/></svg>', title: 'Automatic Alerting', desc: 'Defined thresholds automatically trigger alerts. Recommended actions are displayed directly in the system.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 0 1-1.44-4.282m3.102.069a18.03 18.03 0 0 1-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 0 1 8.835 2.535M10.34 6.66a23.847 23.847 0 0 0 8.835-2.535m0 0A23.74 23.74 0 0 0 18.795 3m.38 1.125a23.91 23.91 0 0 1 1.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 0 0 1.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 0 1 0 3.46"/></svg>', title: 'Integrated Announcements', desc: 'Targeted communication to defined areas. Area broadcasts and emergency broadcasts directly from the situational picture.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>', title: 'Seamless Documentation', desc: 'Automatic logging of all incidents. Audit trail for regulatory evidence and internal audits.' },
        { icon: '<svg class="w-5 h-5 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 0 0 2.25-2.25V6a2.25 2.25 0 0 0-2.25-2.25H6A2.25 2.25 0 0 0 3.75 6v2.25A2.25 2.25 0 0 0 6 10.5Zm0 9.75h2.25A2.25 2.25 0 0 0 10.5 18v-2.25a2.25 2.25 0 0 0-2.25-2.25H6a2.25 2.25 0 0 0-2.25 2.25V18A2.25 2.25 0 0 0 6 20.25Zm9.75-9.75H18a2.25 2.25 0 0 0 2.25-2.25V6A2.25 2.25 0 0 0 18 3.75h-2.25A2.25 2.25 0 0 0 13.5 6v2.25a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>', title: 'Integration into OCC/Control Center', desc: 'MOVETOS Ops complements existing control center systems. Data export, API interfaces and connection to existing infrastructure.' },
      ].map(item => (
        <div class="reveal flex items-start gap-4 p-5 bg-surface border border-dark-border rounded-xl">
          <div class="shrink-0 mt-0.5" set:html={item.icon}></div>
          <div>
            <h3 class="font-display text-sm font-bold mb-1">{item.title}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== DEPLOYMENT SCENARIOS ===== -->
<section class="py-20 md:py-28 bg-dark-card">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">Deployment Scenarios</div>
    <div class="section-title">Where MOVETOS supports critical infrastructure<br><span class="text-brand-orange">operators.</span></div>

    <div class="grid md:grid-cols-2 gap-6 mt-14">
      {[
        { title: 'Airports', desc: 'Perimeter security, terminal monitoring, apron safety. Integration into existing airport control centers.' },
        { title: 'Energy Providers', desc: 'Monitoring of power plant premises, substations and sensitive facilities. Mobile deployment during maintenance phases.' },
        { title: 'Data Centers', desc: 'Perimeter protection and access monitoring for high-security sites. 24/7 monitoring with automatic alerting.' },
        { title: 'Government & Public Institutions', desc: 'Temporary security infrastructure for special situations. Rapidly deployable, immediately operational.' },
      ].map(item => (
        <div class="reveal flex items-start gap-3 p-5 bg-surface border border-dark-border rounded-xl">
          <span class="text-brand-orange text-xs mt-1">&#10003;</span>
          <div>
            <h3 class="font-display text-sm font-bold mb-1">{item.title}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== ROI CALCULATOR ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-10 items-center">
      <div>
        <div class="label">Your ROI in Numbers</div>
        <div class="section-title">How much more efficient<br><span class="text-brand-orange">is your perimeter protection?</span></div>
        <p class="section-desc">
          AI-powered anomaly detection instead of routine patrols: more coverage per operator, faster response in emergencies. Calculate with your numbers.
        </p>
      </div>
      <div>
        <ROICalculator segment="kritis" lang="en" />
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== REFERENCES ===== -->
<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label">Proven at critical infrastructure</div>
    <div class="section-title">Critical Infrastructure Reference.</div>

    <div class="max-w-md mt-14">
      <ReferenceCard
        name="Munich Airport"
        category="Critical Infrastructure"
        visitors="Ongoing"
        highlight="24/7 operations on critical infrastructure"
        quote="Die Integration in unsere bestehenden Systeme verlief reibungslos. MOVETOS Ops ergänzt unsere operative Steuerung ideal."
        quotePerson="Dirk S."
        quoteRole="Head of Operations"
        tags={['MOVETOS Ops', 'Critical Infrastructure', 'Perimeter', '24/7']}
      />
    </div>

    <div class="text-center mt-10">
      <a href={`/en/references/`} class="btn btn-ghost">View All References &rarr;</a>
    </div>
  </div>
</section>

<div class="divider"></div>

<!-- ===== CTA ===== -->
<section class="py-20 md:py-28 text-center">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="label justify-center">Consultation</div>
    <div class="section-title mx-auto" style="max-width: 540px;">
      Your infrastructure.<br>
      <span class="text-brand-orange">Our protection.</span>
    </div>
    <p class="section-desc text-center mx-auto mt-4" style="max-width: 460px;">
      Critical infrastructure requirements are individual. Talk to our experts about your specific needs for perimeter protection and situational awareness.
    </p>
    <div class="flex flex-wrap gap-3 justify-center mt-8">
      <a href={`/en/terrops/demo/`} class="btn btn-primary">Schedule Consultation &rarr;</a>
      <a href="tel:+4981572934870" class="btn btn-ghost">&#9742; 08157 2934870</a>
    </div>
  </div>
</section>

</BaseLayout>
