---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ContactFormInline from '../../../components/ContactFormInline.astro';
---
<BaseLayout
  title="Contact — MOVETOS Germany GmbH"
  description="Get in touch with MOVETOS. Consultation, demo requests, partnerships — we're here for you."
  lang="en"
>

<section class="pt-32 pb-20">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <div>
        <div class="label mb-4">Contact</div>
        <h1 class="section-title">
          Talk to<br>
          <span class="text-brand-orange">us.</span>
        </h1>
        <p class="section-desc mt-4">
          Whether demo request, consultation, or partnership — we look forward to hearing from you.
        </p>

        <div class="mt-10 flex flex-col gap-6">
          <div>
            <h4 class="font-mono text-[10px] font-medium uppercase tracking-[1.5px] text-text-muted mb-2">Phone</h4>
            <a href="tel:+4981572934870" class="text-lg font-display font-semibold text-brand-orange hover:text-brand-orange-light transition-colors">
              +49 8157 2934870
            </a>
          </div>
          <div>
            <h4 class="font-mono text-[10px] font-medium uppercase tracking-[1.5px] text-text-muted mb-2">Email</h4>
            <a href="mailto:kontakt@movetos.de" class="text-lg font-display font-semibold text-brand-orange hover:text-brand-orange-light transition-colors">
              kontakt@movetos.de
            </a>
          </div>
          <div>
            <h4 class="font-mono text-[10px] font-medium uppercase tracking-[1.5px] text-text-muted mb-2">Address</h4>
            <p class="text-sm text-text-secondary leading-relaxed">
              MOVETOS Germany GmbH<br>
              Feldafinger Str. 5<br>
              82343 Pöcking<br>
              Germany
            </p>
          </div>
        </div>
      </div>

      <div class="lg:sticky lg:top-24">
        <ContactFormInline lang="en" />
      </div>
    </div>
  </div>
</section>

</BaseLayout>
