---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ContactFormInline from '../../../components/ContactFormInline.astro';
---
<BaseLayout
  title="Book MOVETOS Ops Live Demo | MOVETOS"
  description="Experience MOVETOS Ops live in a 30-minute demo. We show you the platform with your scenario — no obligation."
>

<section class="pt-32 pb-20">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <div>
        <nav class="flex items-center gap-2 text-xs text-text-muted mb-6">
          <a  href={`/en/`} class="hover:text-text-secondary transition-colors">MOVETOS</a>
          <span>/</span>
          <a  href={`/en/ops/`} class="hover:text-text-secondary transition-colors">MOVETOS Ops</a>
          <span>/</span>
          <span class="text-brand-orange">Demo</span>
        </nav>

        <div class="label mb-4">Get Started</div>
        <h1 class="section-title">
          Experience MOVETOS Ops<br>
          <span class="text-brand-orange">live.</span>
        </h1>
        <p class="section-desc mt-4">
          30 minutes. Your scenario. No obligation. We show you how MOVETOS Ops transforms your operations.
        </p>

        <div class="mt-10 flex flex-col gap-5">
          <div class="flex items-start gap-3">
            <span class="w-8 h-8 rounded-lg bg-accent-green-dim flex items-center justify-center text-sm shrink-0">&#10003;</span>
            <div>
              <h4 class="font-display text-sm font-semibold">Live Demonstration</h4>
              <p class="text-xs text-text-muted mt-0.5">See MOVETOS Ops in live operation — with real data from past deployments.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="w-8 h-8 rounded-lg bg-accent-blue-dim flex items-center justify-center shrink-0"><svg class="w-4 h-4 text-accent-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/></svg></span>
            <div>
              <h4 class="font-display text-sm font-semibold">Your Scenario</h4>
              <p class="text-xs text-text-muted mt-0.5">We discuss your requirements and show how MOVETOS Ops works in your context.</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="w-8 h-8 rounded-lg bg-brand-orange-glow flex items-center justify-center shrink-0"><svg class="w-4 h-4 text-brand-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z"/></svg></span>
            <div>
              <h4 class="font-display text-sm font-semibold">Custom Calculation</h4>
              <p class="text-xs text-text-muted mt-0.5">We calculate the concrete value for your operations — transparent and traceable.</p>
            </div>
          </div>
        </div>

        <div class="mt-10 p-5 bg-surface border border-dark-border rounded-xl">
          <p class="text-sm text-text-secondary">
            <strong class="text-text-primary">Prefer to call?</strong><br>
            Call us directly: <a href="tel:+4981572934870" class="text-brand-orange hover:text-brand-orange-light transition-colors">+49 8157 2934870</a>
          </p>
        </div>
      </div>

      <div class="lg:sticky lg:top-24">
        <ContactFormInline lang="en" />
      </div>
    </div>
  </div>
</section>

</BaseLayout>
