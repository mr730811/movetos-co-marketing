---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Camera Systems — Wireless Mast Systems | MOVETOS"
  description="Wireless camera mast systems for large-scale events. HD/4K, weatherproof, night vision, 5.5 m height. Plug & Play in minutes."
>

<section class="pt-32 pb-20">
  <div class="max-w-[1200px] mx-auto px-6">
    <nav class="flex items-center gap-2 text-xs text-text-muted mb-6">
      <a  href={`${import.meta.env.BASE_URL}/en/`} class="hover:text-text-secondary transition-colors">MOVETOS</a>
      <span>/</span>
      <a  href={`${import.meta.env.BASE_URL}/en/infrastructure/`} class="hover:text-text-secondary transition-colors">Infrastructure</a>
      <span>/</span>
      <span class="text-brand-orange">Camera Systems</span>
    </nav>

    <div class="label mb-4">Camera Systems</div>
    <h1 class="section-title">
      Every location becomes an<br>
      <span class="text-brand-orange">observation point.</span>
    </h1>
    <p class="section-desc mt-4 max-w-2xl">
      Wireless mast systems (5.5 m) with HD and 4K cameras, LED lighting and speakers. Together with the OCC they form the MOVETOS SET — one system, wireless, off-grid.
    </p>
  </div>
</section>

<div class="divider"></div>

<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-10">
      <div>
        <h2 class="font-display text-2xl font-bold mb-6">Technical Highlights</h2>
        <div class="flex flex-col gap-4">
          {[
            { label: 'Resolution', value: 'Full HD 1080p / 4K Ultra HD', desc: 'Crystal-clear images day and night' },
            { label: 'Protection Rating', value: 'IP67 Weatherproof', desc: 'Rain, dust, heat — no problem' },
            { label: 'LED Lighting', value: 'Color images around the clock', desc: 'Integrated LED enables continuous color video analysis — even at night' },
            { label: 'Mast Height', value: '5.5 Meters', desc: 'Optimal perspective for crowd analysis' },
            { label: 'Power Supply', value: 'Battery operation up to 144h', desc: 'Up to 6 days autonomous in 24/7 operation' },
            { label: 'Connectivity', value: 'MOVETOS Mesh Network', desc: 'Automatic connection, no WiFi required' },
          ].map((spec, i) => (
            <div class="reveal flex items-start gap-4 p-4 bg-dark-card border border-dark-border rounded-xl" style={`transition-delay: ${i * 0.06}s`}>
              <div class="flex-1">
                <div class="flex items-baseline gap-2 mb-1">
                  <span class="font-mono text-[9px] uppercase tracking-wider text-text-muted">{spec.label}</span>
                  <span class="font-display text-sm font-semibold text-text-primary">{spec.value}</span>
                </div>
                <p class="text-xs text-text-muted">{spec.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div>
        <img src={`${import.meta.env.BASE_URL}/images/set-mast.jpg`} alt="MOVETOS SET mast system with camera and LED lighting" class="w-full rounded-xl shadow-xl mb-8 object-cover max-h-72" loading="lazy" />
        <h2 class="font-display text-2xl font-bold mb-6">Working with TerrOps</h2>
        <div class="glass-card p-6 mb-6">
          <p class="text-sm text-text-secondary leading-relaxed">
            Every MOVETOS camera is automatically detected by TerrOps. AI-powered analysis starts immediately — visitor counting, density analysis and movement patterns. No setup, no configuration.
          </p>
        </div>
        <div class="flex flex-col gap-3">
          {[
            'Automatic camera detection via mesh',
            'Live stream + AI analysis in real time',
            'Freely definable analysis zones per camera',
            'Privacy zones with automatic masking',
            'Alarm rules configurable per camera',
          ].map(feat => (
            <div class="flex items-center gap-2 text-sm text-text-secondary">
              <span class="text-accent-green text-xs">&#10003;</span> {feat}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<section class="py-20 text-center">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="section-title mx-auto" style="max-width: 480px;">
      How many cameras does<br><span class="text-brand-orange">your event need?</span>
    </div>
    <p class="section-desc text-center mx-auto mt-4">We plan your camera coverage individually — from 5 to 50+ locations.</p>
    <div class="flex flex-wrap gap-3 justify-center mt-8">
      <a  href={`${import.meta.env.BASE_URL}/en/contact/`} class="btn btn-primary">Request Consultation &rarr;</a>
      <a  href={`${import.meta.env.BASE_URL}/en/infrastructure/`} class="btn btn-ghost">&larr; All Systems</a>
    </div>
  </div>
</section>

</BaseLayout>
