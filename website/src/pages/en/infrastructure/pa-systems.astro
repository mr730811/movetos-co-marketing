---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Public Address System (BDS) — Targeted Visitor Communication | MOVETOS"
  description="Wireless public address systems (BDS) for large-scale events. Radio-controlled, weatherproof, optionally with LED lighting and dispatcher solution."
>

<section class="pt-32 pb-20">
  <div class="max-w-[1200px] mx-auto px-6">
    <nav class="flex items-center gap-2 text-xs text-text-muted mb-6">
      <a  href={`${import.meta.env.BASE_URL}/en/`} class="hover:text-text-secondary transition-colors">MOVETOS</a>
      <span>/</span>
      <a  href={`${import.meta.env.BASE_URL}/en/infrastructure/`} class="hover:text-text-secondary transition-colors">Infrastructure</a>
      <span>/</span>
      <span class="text-brand-orange">PA Systems</span>
    </nav>

    <div class="label mb-4">Public Address System (BDS)</div>
    <h1 class="section-title">
      The right information<br>at the <span class="text-brand-orange">right place.</span>
    </h1>
    <p class="section-desc mt-4 max-w-2xl">
      Individual wireless public address systems (BDS) for targeted visitor communication. Radio-controlled, with own power supply, optionally with LED lighting (LRD) and dispatcher solution for automated announcements.
    </p>
  </div>
</section>

<div class="divider"></div>

<section class="py-20 md:py-28">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-10">
      <div>
        <h2 class="font-display text-2xl font-bold mb-6">Technical Highlights</h2>
        <div class="flex flex-col gap-4">
          {[
            { label: 'Technology', value: '100V Line System', desc: 'Professional PA technology for best speech intelligibility' },
            { label: 'Sound Level', value: '100 dB at 100 m', desc: 'Real-world value outdoors — clearly audible even with ambient noise' },
            { label: 'Control', value: 'Sectorally Addressable', desc: 'Each speaker individually or in groups addressable' },
            { label: 'Protection Rating', value: 'IP65+ Weatherproof', desc: 'Reliable in any weather condition' },
            { label: 'Speech Synthesis', value: 'TTS Integration', desc: 'Automated announcements in multiple languages via TerrOps' },
            { label: 'Templates', value: 'Template System', desc: 'Predefined announcement texts for typical scenarios' },
          ].map((spec, i) => (
            <div class="reveal flex items-start gap-4 p-4 bg-dark-card border border-dark-border rounded-xl" style={`transition-delay: ${i * 0.06}s`}>
              <div class="flex-1">
                <div class="flex items-baseline gap-2 mb-1">
                  <span class="font-mono text-[9px] uppercase tracking-wider text-text-muted">{spec.label}</span>
                  <span class="font-display text-sm font-semibold text-text-primary">{spec.value}</span>
                </div>
                <p class="text-xs text-text-muted">{spec.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div>
        <img src={`${import.meta.env.BASE_URL}/images/bds-system.jpg`} alt="MOVETOS Public Address System (BDS)" class="w-full rounded-xl shadow-xl mb-8 object-cover max-h-72" loading="lazy" />
        <h2 class="font-display text-2xl font-bold mb-6">Intelligent with TerrOps</h2>
        <div class="glass-card p-6 mb-6">
          <p class="text-sm text-text-secondary leading-relaxed">
            TerrOps controls the PA systems with zone-level precision. When capacity increases, a routing recommendation can be automatically triggered in the affected sector — or the operator confirms the suggestion with a single click.
          </p>
        </div>
        <div class="flex flex-col gap-3">
          {[
            'Automatic announcements on capacity alerts',
            'Sectoral control via map view',
            'Multi-language TTS speech synthesis',
            'Templates for standard scenarios (routing, evacuation, emergency, weather warnings)',
            'Jingle and pre-recording management',
            'Evacuation announcements to affected zones — targeted and multilingual',
            'Logging of all announcements in the audit trail',
          ].map(feat => (
            <div class="flex items-center gap-2 text-sm text-text-secondary">
              <span class="text-accent-green text-xs">&#10003;</span> {feat}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<div class="divider"></div>

<section class="py-20 text-center">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="section-title mx-auto" style="max-width: 480px;">
      Targeted communication<br>for <span class="text-brand-orange">your event.</span>
    </div>
    <p class="section-desc text-center mx-auto mt-4">We plan your sound coverage individually — from individual zones to full coverage.</p>
    <div class="flex flex-wrap gap-3 justify-center mt-8">
      <a  href={`${import.meta.env.BASE_URL}/en/contact/`} class="btn btn-primary">Request Consultation &rarr;</a>
      <a  href={`${import.meta.env.BASE_URL}/en/infrastructure/`} class="btn btn-ghost">&larr; All Systems</a>
    </div>
  </div>
</section>

</BaseLayout>
